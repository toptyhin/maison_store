{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-total" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-total" class="form-horizontal">
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="total_wholesale_discount_status" id="input-status" class="form-control">
                {% if total_wholesale_discount_status %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                <option value="0">{{ text_disabled }}</option>
                {% else %}
                <option value="1">{{ text_enabled }}</option>
                <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="total_wholesale_discount_sort_order" value="{{ total_wholesale_discount_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_customer_group_tiers }}</label>
            <div class="col-sm-10">
              {% for customer_group in customer_groups %}
              {% set customer_group_id = customer_group.customer_group_id %}
              {% set tiers = total_wholesale_discount_customer_group_tiers[customer_group_id] ?? [] %}
              <div class="panel panel-default">
                <div class="panel-heading"><strong>{{ customer_group.name }}</strong></div>
                <div class="panel-body">
                  <table class="table table-striped table-bordered table-hover">
                    <thead>
                      <tr>
                        <th>{{ entry_threshold }}</th>
                        <th>{{ entry_percent }}</th>
                        <th style="width: 80px;"></th>
                      </tr>
                    </thead>
                    <tbody id="tiers-{{ customer_group_id }}">
                      {% if tiers %}
                        {% for tier in tiers %}
                        <tr>
                          <td><input type="number" step="0.01" min="0" name="total_wholesale_discount_customer_group_tiers[{{ customer_group_id }}][{{ loop.index0 }}][threshold]" value="{{ tier.threshold }}" class="form-control" /></td>
                          <td><input type="number" step="0.01" min="0" name="total_wholesale_discount_customer_group_tiers[{{ customer_group_id }}][{{ loop.index0 }}][percent]" value="{{ tier.percent }}" class="form-control" /></td>
                          <td class="text-center"><button type="button" class="btn btn-danger js-remove-tier"><i class="fa fa-minus-circle"></i></button></td>
                        </tr>
                        {% endfor %}
                      {% else %}
                        <tr class="js-empty-row">
                          <td colspan="3" class="text-muted text-center">{{ text_no_tiers }}</td>
                        </tr>
                      {% endif %}
                    </tbody>
                    <tfoot>
                      <tr>
                        <td colspan="3" class="text-right">
                          <button
                            type="button"
                            class="btn btn-primary js-add-tier"
                            data-group-id="{{ customer_group_id }}"
                            data-threshold-label="{{ entry_threshold }}"
                            data-percent-label="{{ entry_percent }}"
                            data-remove-label="{{ button_remove_tier }}"
                          >
                            <i class="fa fa-plus-circle"></i> {{ button_add_tier }}
                          </button>
                        </td>
                      </tr>
                    </tfoot>
                  </table>
                </div>
              </div>
              {% endfor %}
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript">
(function() {
  function updateIndexes(groupId) {
    var tbody = document.getElementById('tiers-' + groupId);
    if (!tbody) return;

    var rows = tbody.querySelectorAll('tr:not(.js-empty-row)');
    for (var i = 0; i < rows.length; i++) {
      var thresholdInput = rows[i].querySelector('input[name*="[threshold]"]');
      var percentInput = rows[i].querySelector('input[name*="[percent]"]');

      if (thresholdInput) {
        thresholdInput.name = 'total_wholesale_discount_customer_group_tiers[' + groupId + '][' + i + '][threshold]';
      }

      if (percentInput) {
        percentInput.name = 'total_wholesale_discount_customer_group_tiers[' + groupId + '][' + i + '][percent]';
      }
    }
  }

  function addRow(groupId) {
    var tbody = document.getElementById('tiers-' + groupId);
    if (!tbody) return;

    var emptyRow = tbody.querySelector('.js-empty-row');
    if (emptyRow) {
      emptyRow.remove();
    }

    var rowIndex = tbody.querySelectorAll('tr').length;
    var tr = document.createElement('tr');
    tr.innerHTML =
      '<td><input type="number" step="0.01" min="0" name="total_wholesale_discount_customer_group_tiers[' + groupId + '][' + rowIndex + '][threshold]" value="" class="form-control" /></td>' +
      '<td><input type="number" step="0.01" min="0" name="total_wholesale_discount_customer_group_tiers[' + groupId + '][' + rowIndex + '][percent]" value="" class="form-control" /></td>' +
      '<td class="text-center"><button type="button" class="btn btn-danger js-remove-tier"><i class="fa fa-minus-circle"></i></button></td>';
    tbody.appendChild(tr);
  }

  function ensureEmptyRow(groupId) {
    var tbody = document.getElementById('tiers-' + groupId);
    if (!tbody) return;

    if (tbody.querySelectorAll('tr').length === 0) {
      var tr = document.createElement('tr');
      tr.className = 'js-empty-row';
      tr.innerHTML = '<td colspan="3" class="text-muted text-center">{{ text_no_tiers|e('js') }}</td>';
      tbody.appendChild(tr);
    }
  }

  document.addEventListener('click', function(event) {
    var addButton = event.target.closest('.js-add-tier');
    if (addButton) {
      event.preventDefault();
      addRow(addButton.getAttribute('data-group-id'));
      return;
    }

    var removeButton = event.target.closest('.js-remove-tier');
    if (removeButton) {
      event.preventDefault();
      var row = removeButton.closest('tr');
      if (!row) return;

      var tbody = row.parentNode;
      var match = (tbody.id || '').match(/^tiers-(\d+)$/);
      row.remove();

      if (match) {
        updateIndexes(match[1]);
        ensureEmptyRow(match[1]);
      }
    }
  });
})();
</script>
{{ footer }}
