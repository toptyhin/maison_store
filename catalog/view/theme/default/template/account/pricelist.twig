{{ header }}
<div id="account-pricelist" class="container">
  <ul class="breadcrumb">
    {% for breadcrumb in breadcrumbs %}
    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
    {% endfor %}
  </ul>
  <div class="row">{{ column_left }}
    {% if column_left and column_right %}
    {% set class = 'col-sm-6' %}
    {% elseif column_left or column_right %}
    {% set class = 'col-sm-9' %}
    {% else %}
    {% set class = 'col-sm-12' %}
    {% endif %}
    <div id="content" class="{{ class }}">{{ content_top }}
      <h2>{{ heading_title }}</h2>
      {% if error %}
      <div class="alert alert-danger">{{ error }}</div>
      {% endif %}
      <form method="post" action="{{ download_action }}" id="form-pricelist">
        <p>{{ text_select_categories }}</p>
        <div class="form-group" style="max-height: 300px; overflow-y: auto; border: 1px solid #ddd; padding: 10px;">
          {% for category in categories %}
          <label class="checkbox">
            <input type="checkbox" name="category[]" value="{{ category.category_id }}" /> {{ category.name|raw }}
          </label>
          {% for child in category.children %}
          <label class="checkbox" style="margin-left: 20px;">
            <input type="checkbox" name="category[]" value="{{ child.category_id }}" /> {{ child.name|raw }}
          </label>
          {% for subchild in child.children %}
          <label class="checkbox" style="margin-left: 40px;">
            <input type="checkbox" name="category[]" value="{{ subchild.category_id }}" /> {{ subchild.name|raw }}
          </label>
          {% endfor %}
          {% endfor %}
          {% endfor %}
        </div>
        <div class="buttons">
          <button type="submit" name="format" value="csv" class="btn btn-primary"><i class="fa fa-download"></i> {{ button_download_csv }}</button>
          <button type="submit" name="format" value="xls" class="btn btn-default"><i class="fa fa-download"></i> {{ button_download_xls }}</button>
        </div>
      </form>
      <div class="buttons clearfix">
        <div class="pull-right"><a href="{{ continue }}" class="btn btn-primary">{{ button_continue }}</a></div>
      </div>
      {{ content_bottom }}</div>
    {{ column_right }}</div>
</div>
{{ footer }}
