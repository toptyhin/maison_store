            <div class="flex items-center gap-6 lg:gap-12 min-w-0">
                <a href="{{ continue }}" class="flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-gray-500 hover:text-luxury-charcoal transition-colors group shrink-0">
