    #app-root > header.fixed {
        display: none !important;
    }
    html,
    body {
        margin: 0 !important;
        padding-top: 0 !important;
    }
</style>

    <header class="fixed top-0 left-0 right-0 z-[55] bg-white/95 backdrop-blur-md border-b border-gray-200 transition-all duration-300 shadow-sm w-full">
