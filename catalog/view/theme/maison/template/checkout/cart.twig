{{ header }}

<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden bg-background-dark">
{{ include('maison/template/checkout/checkout_header.twig') }}


    <main class="flex-1 w-full max-w-7xl mx-auto px-6 lg:px-12 py-12">
        <div id="cart-page-content">
            {{ include('maison/template/checkout/cart_content.twig') }}
        </div>
    </main>
</div>

{{ footer }}

<script>
    var cartPageUrl = '{{ base }}index.php?route=checkout/cart';
    var cartContentUrl = '{{ base }}index.php?route=checkout/cart/content';
    var cartRemoveUrl = '{{ base }}index.php?route=checkout/cart/remove';
    var cartAddUrl = '{{ base }}index.php?route=checkout/cart/add';
    var cartEditUrl = '{{ base }}index.php?route=checkout/cart/edit';

    function refreshCartContent() {
        var container = document.getElementById('cart-page-content');
        if (!container) return;
        fetch(cartContentUrl, {
            method: 'GET',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
            .then(function (r) { return r.json(); })
            .then(function (json) {
                if (json && json.html) {
                    container.innerHTML = json.html;
                }
            })
            .catch(function () {
                window.location.href = cartPageUrl;
            });
    }

    function addUpsellToCart(productId, quantity, addOption) {
        var body = 'product_id=' + productId + '&quantity=' + (quantity || 1);
        if (addOption) {
            body += '&' + addOption;
        }
        fetch(cartAddUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
            body: body
        })
            .then(function (r) { return r.json(); })
            .then(function (json) {
                if (json.redirect) {
                    location = json.redirect;
                } else if (json.success) {
                    refreshCartContent();
                } else if (json.error && json.error.option) {
                    var msg = Object.values(json.error.option).join(' ');
                    alert(msg || 'Выберите опцию товара на странице товара.');
                } else if (json.error) {
                    alert(json.error);
                }
            })
            .catch(function () { alert('Ошибка добавления в корзину.'); });
    }

    function removeFromCart(btn, cartId) {
        if (!btn || !cartId) return;
        btn.disabled = true;
        var icon = btn.querySelector('.cart-remove-icon');
        if (icon) {
            icon.textContent = 'hourglass_empty';
            icon.classList.add('animate-pulse');
        }

        fetch(cartRemoveUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: 'key=' + encodeURIComponent(cartId)
        })
            .then(function (response) { return response.json(); })
            .then(function (json) {
                if (json.success) {
                    refreshCartContent();
                } else {
                    btn.disabled = false;
                    if (icon) {
                        icon.textContent = 'delete';
                        icon.classList.remove('animate-pulse');
                    }
                    alert(json.error || 'Не удалось удалить товар.');
                }
            })
            .catch(function () {
                btn.disabled = false;
                if (icon) {
                    icon.textContent = 'delete';
                    icon.classList.remove('animate-pulse');
                }
                alert('Ошибка соединения. Попробуйте еще раз.');
            });
    }

    function updateCartQuantity(cartId, delta) {
        var form = document.getElementById('cart-form');
        if (!form) return;

        var input = form.querySelector('input[name="quantity[' + cartId + ']"]');
        if (!input) return;

        var current = parseInt(input.value, 10);
        if (isNaN(current)) current = 1;

        var next = current + delta;
        if (next < 1) {
            next = 1;
        }

        input.value = next;

        var formData = new FormData(form);
        var body = new URLSearchParams();
        formData.forEach(function (value, key) {
            if (key.indexOf('quantity') === 0) {
                body.append(key, value);
            }
        });

        fetch(cartEditUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: body.toString()
        })
            .then(function (r) { return r.json(); })
            .then(function (json) {
                if (json.success) {
                    refreshCartContent();
                } else {
                    window.location.href = cartPageUrl;
                }
            })
            .catch(function () {
                window.location.href = cartPageUrl;
            });
    }

    function applyCartCoupon() {
        var input = document.getElementById('cart-coupon-input');
        var message = document.getElementById('cart-coupon-message');
        if (!input || !message) return;

        var code = input.value.trim();
        if (!code) {
            message.textContent = 'Введите промокод';
            message.classList.remove('hidden');
            message.classList.add('text-red-600');
            return;
        }

        message.classList.add('hidden');
        message.textContent = '';

        fetch('{{ coupon_action }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: 'coupon=' + encodeURIComponent(code)
        })
            .then(function (response) { return response.json(); })
            .then(function (json) {
                if (json.error) {
                    message.textContent = json.error;
                    message.classList.remove('hidden');
                    message.classList.add('text-red-600');
                } else if (json.redirect) {
                    refreshCartContent();
                }
            })
            .catch(function () {
                message.textContent = 'Ошибка применения промокода. Попробуйте еще раз.';
                message.classList.remove('hidden');
                message.classList.add('text-red-600');
            });
    }
</script>