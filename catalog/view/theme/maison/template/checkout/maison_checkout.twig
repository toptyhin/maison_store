    async function loadShippingMethod() {
        const container = document.getElementById('maison-shipping-method-section');
        if (!container) return;
        const section = container.closest('section');
        const previousContent = container.innerHTML;
        showLoading(container);
        try {
            const html = await fetchHtml('checkout/shipping_method');
            if (!html || !html.includes('maison-carrier-radio')) {
                container.innerHTML = previousContent;
                if (section) showErrorInSection(section, 'Не удалось загрузить варианты доставки. Проверьте адрес и попробуйте снова.');
