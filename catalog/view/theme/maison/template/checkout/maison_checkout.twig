    function initShippingMethodDebounce() {
        const container = document.getElementById('maison-shipping-method-section');
        if (!container || container.dataset.shippingDebounceInit) return;
        container.dataset.shippingDebounceInit = '1';
        const carrierRadios = container.querySelectorAll('input.maison-carrier-radio');
        const deliveryTypeRadios = container.querySelectorAll('input[name="delivery_type"]');
        const commentEl = container.querySelector('textarea[name="comment"]');
