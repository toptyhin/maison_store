    const YANDEX_MAPS_API_KEY = '';

    let ymapsReady = false;
    let ymapsLoading = false;
    let ymapsCallbacks = [];

    function loadYmaps(cb) {
        if (ymapsReady) { cb(); return; }
        ymapsCallbacks.push(cb);
        if (ymapsLoading) return;
        ymapsLoading = true;
        const script = document.createElement('script');
        const key = YANDEX_MAPS_API_KEY ? '&apikey=' + YANDEX_MAPS_API_KEY : '';
        script.src = 'https://api-maps.yandex.ru/2.1/?lang=ru_RU' + key;
        script.onload = function() {
            ymaps.ready(function() {
                ymapsReady = true;
                ymapsCallbacks.forEach(fn => fn());
                ymapsCallbacks = [];
            });
        };
        document.head.appendChild(script);
    }

    let pickupMap = null;
    let selectedPickupPoint = null;

    function initPickupMap() {
        const placeholder = document.getElementById('maison-pickup-map-placeholder');
        const mapContainer = document.getElementById('maison-pickup-map-container');
        if (!placeholder || !mapContainer) return;

        placeholder.classList.add('hidden');
        mapContainer.classList.remove('hidden');
        mapContainer.classList.add('flex');

        if (pickupMap) { pickupMap.container.fitToViewport(); return; }

        pickupMap = new ymaps.Map('maison-ymap', {
            center: [55.751574, 37.573856],
            zoom: 10,
            controls: ['zoomControl', 'geolocationControl']
        });

        const searchControl = new ymaps.control.SearchControl({
            options: { float: 'right', noPlacemark: true }
        });
        pickupMap.controls.add(searchControl);

        pickupMap.events.add('click', function(e) {
            const coords = e.get('coords');
            setPickupCoords(coords);
        });
    }

    function setPickupCoords(coords) {
        if (!pickupMap) return;
        pickupMap.geoObjects.removeAll();
        const placemark = new ymaps.Placemark(coords, {}, {
            preset: 'islands#darkBlueDotIconWithCaption',
            iconCaptionMaxWidth: '200'
        });
        pickupMap.geoObjects.add(placemark);
        selectedPickupPoint = coords;

        ymaps.geocode(coords, { results: 1 }).then(function(res) {
            const obj = res.geoObjects.get(0);
            const address = obj ? obj.getAddressLine() : coords[0].toFixed(5) + ', ' + coords[1].toFixed(5);
            placemark.properties.set('iconCaption', address);
            const infoEl = document.getElementById('maison-pickup-selected-info');
            if (infoEl) infoEl.textContent = address;
            const shippingInput = document.getElementById('maison-shipping-address-input');
            if (shippingInput) shippingInput.value = address;
        });
    }

    function initPickupMapListeners() {
        const openBtn = document.getElementById('maison-pickup-map-open-btn');
        const closeBtn = document.getElementById('maison-pickup-map-close-btn');
        if (openBtn && !openBtn.dataset.mapInit) {
            openBtn.dataset.mapInit = '1';
            openBtn.addEventListener('click', function() {
                loadYmaps(initPickupMap);
            });
        }
        if (closeBtn && !closeBtn.dataset.mapInit) {
            closeBtn.dataset.mapInit = '1';
            closeBtn.addEventListener('click', function() {
                document.getElementById('maison-pickup-map-placeholder')?.classList.remove('hidden');
                const mapContainer = document.getElementById('maison-pickup-map-container');
                if (mapContainer) {
                    mapContainer.classList.add('hidden');
                    mapContainer.classList.remove('flex');
                }
            });
        }
    }

