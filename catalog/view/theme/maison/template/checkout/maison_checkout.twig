    async function saveShippingMethod() {
        const container = document.getElementById('maison-shipping-method-section');
        const formData = new FormData();
        const carrierRadio = container && container.querySelector('input.maison-carrier-radio:checked');
        const deliveryTypeRadio = container && container.querySelector('input[name="delivery_type"]:checked');
        if (carrierRadio && deliveryTypeRadio) {
            formData.set('shipping_method', carrierRadio.value + '.' + deliveryTypeRadio.value);
        } else if (carrierRadio) {
            formData.set('shipping_method', carrierRadio.value);
        }
        const comment = container && container.querySelector('textarea[name="comment"]');
        if (comment) formData.set('comment', comment.value);

        const btn = document.getElementById('maison-shipping-method-btn');
        if (btn) btn.disabled = true;
        try {
            const json = await fetchJson('checkout/shipping_method/save', formData);
            if (json.redirect) {
                window.location = json.redirect;
                return;
            }
            if (json.error) {
                showErrorInSection(container, json.error.warning || 'Ошибка');
                if (btn) btn.disabled = false;
                return;
            }
            showErrorInSection(container, '');
            // Обновление тоталов с учётом стоимости доставки
            if (json.order_total_text) {
                const subEl = document.getElementById('maison-order-sub-total');
                const shipEl = document.getElementById('maison-order-shipping');
                const totalEl = document.getElementById('maison-order-total');
                const discountRow = document.getElementById('maison-order-discount-row');
                const discountEl = document.getElementById('maison-order-discount');
                if (subEl && json.sub_total_text) subEl.textContent = json.sub_total_text;
                if (shipEl) {
                    shipEl.textContent = json.shipping_text || '—';
                    shipEl.classList.toggle('text-green-600', json.shipping_text === 'Бесплатно');
                    shipEl.classList.toggle('text-luxury-charcoal', json.shipping_text !== 'Бесплатно');
                }
                if (totalEl) totalEl.textContent = json.order_total_text;
                if (discountRow && discountEl) {
                    if (json.discount_text) {
                        discountEl.textContent = json.discount_text;
                        discountRow.classList.remove('hidden');
                    } else {
                        discountRow.classList.add('hidden');
                    }
                }
            }
        } catch (e) {
            showErrorInSection(container, 'Ошибка: ' + e.message);
        }
        if (btn) btn.disabled = false;
    }

