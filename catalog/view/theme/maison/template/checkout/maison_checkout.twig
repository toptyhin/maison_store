                            </div>
                        </div>
                    </section>
                    <section class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="size-10 rounded-full bg-gray-50 flex items-center justify-center text-luxury-charcoal border border-gray-100">
                                <span class="material-symbols-outlined">account_balance</span>
                            </div>
                            <h2 class="text-xl font-serif font-medium">Банковские реквизиты</h2>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">БИК</label>
                                <input name="ur_bik" class="w-full rounded-sm border-gray-200 bg-gray-50 py-3 px-3 text-sm focus:border-luxury-charcoal focus:ring-0 placeholder:text-gray-400 transition-colors" placeholder="044525225" type="text" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Название банка</label>
                                <input name="ur_bank" class="w-full rounded-sm border-gray-200 bg-gray-50 py-3 px-3 text-sm focus:border-luxury-charcoal focus:ring-0 placeholder:text-gray-400 transition-colors" placeholder="ПАО Сбербанк" type="text" />
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Расчетный счет</label>
                                <input name="ur_rs" class="w-full rounded-sm border-gray-200 bg-gray-50 py-3 px-3 text-sm focus:border-luxury-charcoal focus:ring-0 placeholder:text-gray-400 transition-colors" placeholder="40702810938000000000" type="text" />
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Корреспондентский счет</label>
                                <input name="ur_ks" class="w-full rounded-sm border-gray-200 bg-gray-50 py-3 px-3 text-sm focus:border-luxury-charcoal focus:ring-0 placeholder:text-gray-400 transition-colors" placeholder="30101810400000000225" type="text" />
                            </div>
                        </div>
                    </section>
                    <div class="flex items-center gap-3">
                        <button type="button" id="maison-ur-lic-submit-btn" class="bg-[#263238] text-white border border-transparent py-4 px-8 font-bold uppercase text-sm tracking-[0.15em] rounded-sm transition-colors hover:bg-primary-dark shadow-lg">
                            Сформировать счет
                        </button>
                        <button type="button" id="maison-ur-lic-back-btn" class="text-gray-500 hover:text-luxury-charcoal py-4 px-4 font-medium text-sm transition-colors">
                            Назад
                        </button>
                    </div>
                </div>

                <section class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100">
                    <h2 class="text-xl font-serif font-medium mb-2 flex items-center gap-2">
                        <span class="material-symbols-outlined text-luxury-charcoal">loyalty</span>
                        Бонусная программа
                    </h2>
                    <p class="text-sm text-gray-500">Доступно баллов будет рассчитано после ввода данных</p>
                </section>
            </div>

            <div class="lg:col-span-4 relative">
                <div class="sticky top-24 flex flex-col gap-6">
                    <section class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100">
                        <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-3">Промокод</label>
                        <div class="flex flex-col gap-3">
                            <input id="maison-coupon-input" class="w-full rounded-sm border-gray-200 bg-gray-50 py-3 px-3 text-sm focus:border-luxury-charcoal focus:ring-0 placeholder:text-gray-400" placeholder="Введите код" type="text"/>
                            <button type="button" id="maison-coupon-btn" class="w-full bg-[#263238] text-white border border-transparent px-6 py-3 text-xs font-bold uppercase tracking-widest hover:bg-primary-dark transition-colors rounded-sm shadow-sm">
                                Применить
                            </button>
                        </div>
                    </section>

                    <div class="bg-white p-6 md:p-8 rounded-lg shadow-card-depth border border-gray-100 relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-full pointer-events-none"></div>
                        <h2 class="text-xl font-serif font-medium mb-6 relative z-10">Ваш заказ</h2>
                        <div id="maison-order-summary" class="flex flex-col gap-4 mb-6 border-b border-gray-100 pb-6 relative z-10">
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-gray-500">{{ items_count }} {{ items_count == 1 ? 'товар' : (items_count < 5 ? 'товара' : 'товаров') }} на сумму</span>
                                <span id="maison-order-sub-total" class="text-luxury-charcoal font-medium">{{ sub_total_text }}</span>
                            </div>
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-gray-500">Доставка</span>
                                <span id="maison-order-shipping" class="{% if shipping_text == 'Бесплатно' %}text-green-600{% else %}text-luxury-charcoal{% endif %} font-bold uppercase text-xs tracking-wide">{{ shipping_text }}</span>
                            </div>
                            <div id="maison-order-discount-row" class="flex justify-between items-center text-sm {% if not discount_text %}hidden{% endif %}">
                                <span class="text-gray-500">Ваша скидка</span>
                                <span id="maison-order-discount" class="text-red-600 font-medium">{{ discount_text }}</span>
                            </div>
                        </div>
                        <div class="flex justify-between items-baseline mb-8 relative z-10">
                            <span class="text-lg font-serif font-medium text-luxury-charcoal">Итого к оплате</span>
                            <span id="maison-order-total" class="text-3xl font-bold text-luxury-charcoal tracking-tight">{% if order_total_text %}{{ order_total_text }}{% else %}{{ sub_total_text }}{% endif %}</span>
                        </div>
                        <div id="maison-confirm-section">
                            <button type="button" id="maison-confirm-order-btn"
                                class="w-full bg-[#263238] text-white border border-transparent py-4 font-bold uppercase text-sm tracking-[0.15em] mb-6 rounded-sm transition-colors hover:bg-primary-dark shadow-lg">
                                Подтвердить заказ
                            </button>                        
                        </div>
                        
                        <div class="text-[10px] leading-relaxed text-gray-400 text-center mt-4">
                            Нажимая кнопку «Подтвердить заказ», вы соглашаетесь с <a class="underline hover:text-luxury-charcoal" href="#">политикой обработки данных</a> и <a class="underline hover:text-luxury-charcoal" href="#">условиями продажи</a>.
                        </div>
                    </div>

                    <div class="flex items-center justify-center gap-6 text-gray-300">
                        <span class="material-symbols-outlined text-[24px]">lock</span>
                        <span class="material-symbols-outlined text-[24px]">verified_user</span>
                        <span class="material-symbols-outlined text-[24px]">local_shipping</span>
                    </div>
                    <div class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100 flex flex-col items-center text-center">
                        <div class="flex flex-col items-center justify-center gap-3 mb-6 w-full">
                            <div class="size-12 rounded-full bg-gray-50 flex items-center justify-center text-luxury-charcoal mx-auto">
                                <span class="material-symbols-outlined text-[24px]">help</span>
                            </div>
                            <h3 class="font-serif font-medium text-xl text-luxury-charcoal text-center">Нужна помощь?</h3>
                        </div>
                        <div class="flex flex-col items-center justify-center gap-4 w-full">
                            <a class="text-luxury-charcoal hover:text-primary-dark transition-colors text-center" href="tel:88005553535">
                                <span class="font-display font-bold text-xl tracking-wide">8 (800) 555-35-35</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
