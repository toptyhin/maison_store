            if (section) showErrorInSection(section, '');
            initShippingMethodDebounce();
            initPickupMapListeners();
        } catch (e) {
            container.innerHTML = previousContent;
            if (section) showErrorInSection(section, 'Ошибка загрузки вариантов доставки: ' + e.message);
