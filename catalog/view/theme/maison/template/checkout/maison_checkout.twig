{{ header }}
{% if dadata_token %}
<link href="https://cdn.jsdelivr.net/npm/@dadata/suggestions@25.11.0/dist/suggestions.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/@dadata/suggestions@25.11.0/dist/suggestions.min.js"></script>
{% endif %}
<style>
    .peer:checked ~ .custom-radio-border { border-color: #263238; background-color: #F5F7FA; }
    .peer:checked ~ .custom-radio-border .radio-indicator { border-color: #263238; }
    .peer:checked ~ .custom-radio-border .radio-indicator::after { transform: scale(1); }
    #maison-checkout .form-control { width: 100%; border-radius: 0.125rem; border: 1px solid #e5e7eb; background: #f9fafb; padding: 0.75rem; font-size: 0.875rem; }
    #maison-checkout .form-control:focus { border-color: #263238; outline: none; }
    #maison-checkout .form-group { margin-bottom: 1rem; }
    #maison-checkout .control-label { display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #6b7280; margin-bottom: 0.5rem; }
    #maison-checkout .maison-field-error { border-color: #dc2626 !important; background-color: #fef2f2 !important; }
    #maison-checkout .maison-section-highlight-error { border-color: #dc2626; box-shadow: 0 0 0 1px #dc2626; }
</style>
<div id="maison-checkout" class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden bg-background-dark font-display text-luxury-charcoal antialiased">
    {{ include('maison/template/checkout/checkout_header.twig') }}
    <main class="flex-1 w-full max-w-7xl mx-auto px-6 lg:px-12 py-12">
        {% if error_warning %}
        <div class="mb-4 rounded-md border border-red-100 bg-red-50 px-4 py-3 text-sm text-red-900 flex items-start gap-2">
            <span class="material-symbols-outlined text-[18px] mt-0.5">error</span>
            <div class="flex-1">{{ error_warning }}</div>
        </div>
        {% endif %}

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <h1 class="text-3xl md:text-4xl font-serif font-bold text-luxury-charcoal">Оформление заказа</h1>
            <div class="flex items-center gap-4 text-xs md:text-sm font-medium">
                <a href="{{ cart_link }}" class="flex items-center gap-2 text-gray-400 hover:text-luxury-charcoal"><span>1. Корзина</span></a>
                <div class="h-px w-6 bg-gray-300"></div>
                <span class="flex items-center gap-2 text-luxury-charcoal font-bold">2. Оформление заказа</span>
                <div class="h-px w-6 bg-gray-300"></div>
                <span class="flex items-center gap-2 text-gray-400">3. Готово</span>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
            <div class="lg:col-span-8 flex flex-col gap-8">
                <section id="maison-contact-section-wrapper" class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100">
                    <h2 class="text-xl font-serif font-medium mb-6">Данные получателя</h2>
                    <div id="maison-contact-section">
                        <div class="flex justify-center py-8 text-gray-400">
                            <span class="animate-pulse">Загрузка формы...</span>
                        </div>
                    </div>
                </section>

                {% if shipping_required %}
                <section id="maison-shipping-section-wrapper" class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100">
                    <h2 class="text-xl font-serif font-medium mb-6">Доставка</h2>
                    <div class="mb-8">
                        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-4">Транспортная компания</h3>
                        <div id="maison-shipping-method-section">{% if shipping_method_html %}{{ shipping_method_html|raw }}{% endif %}</div>
                    </div>

                    <div class="pt-6 border-t border-gray-100">
                        {# <div id="maison-courier-address-header" class="flex items-center justify-between mb-4 hidden">
                            <h3 class="text-xs font-bold uppercase tracking-widest text-gray-500">Адрес доставки</h3>
                        </div> #}
                        <div class="space-y-4 mb-6 relative">
                            <div id="maison-shipping-address-section" class="hidden">
                            </div>
                            <div id="maison-pickup-map-block" class="hidden">
                                <div id="maison-pickup-map-placeholder" class="h-32 w-full bg-gray-100 rounded-md border border-gray-200 flex items-center justify-center text-gray-400 relative overflow-hidden cursor-pointer">
                                    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#263238_1px,transparent_1px)] [background-size:16px_16px]"></div>
                                    <button id="maison-pickup-map-open-btn" type="button" class="relative z-10 flex items-center gap-2 bg-white text-luxury-charcoal px-5 py-2.5 rounded-full shadow-md font-bold text-xs uppercase tracking-widest hover:bg-luxury-charcoal hover:text-white transition-all duration-300 border border-transparent hover:border-white/20">
                                        <span class="material-symbols-outlined text-lg">map</span>
                                        Выбрать на карте
                                    </button>
                                </div>
                                <div id="maison-pickup-map-container" class="hidden flex-col rounded-md border border-gray-200 overflow-hidden">
