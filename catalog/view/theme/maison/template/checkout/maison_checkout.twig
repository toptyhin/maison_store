    function validateAndConfirmOrder() {
        clearValidationHighlights();
        const errors = [];

        const contactSection = document.getElementById('maison-contact-section');
        const contactForm = document.querySelector('#maison-contact-form') || contactSection?.querySelector('form');
        const requiredContact = ['firstname', 'email', 'telephone'];
        if (contactForm) {
            for (const name of requiredContact) {
                const el = contactForm.querySelector(`input[name="${name}"]`);
                if (el && !(el.value || '').trim()) {
                    el.classList.add('maison-field-error');
                    errors.push({ section: contactSection, message: 'Заполните все обязательные поля' });
                }
            }
            if (shippingRequired) {
                const addressSection = document.getElementById('maison-shipping-address-section');
                const addressEl = document.querySelector('#input-payment-address-1') || document.querySelector('#input-shipping-address-1') || contactForm.querySelector('input[name="address_1"]');
                if (addressEl && (addressEl.value || '').trim().length < 3) {
                    addressEl.classList.add('maison-field-error');
                    if (addressSection) {
                        errors.push({ section: addressSection.closest('section'), message: 'Укажите адрес доставки' });
                        addressSection.closest('section')?.classList.add('maison-section-highlight-error');
                        showErrorInSection(addressSection, 'Укажите адрес доставки');
                    }
                }
            }
            if (errors.some(e => e.section === contactSection)) {
                contactSection?.closest('section')?.classList.add('maison-section-highlight-error');
                showErrorInSection(contactSection, errors.find(e => e.section === contactSection)?.message || 'Заполните данные получателя');
            }
        }

        if (shippingRequired) {
            const shippingSection = document.getElementById('maison-shipping-method-section');
            const shippingSectionParent = shippingSection?.closest('section');
            const carrierRadio = shippingSection?.querySelector('input.maison-carrier-radio:checked');
            const deliveryTypeRadio = shippingSection?.querySelector('input[name="delivery_type"]:checked');
            if (!carrierRadio || !deliveryTypeRadio) {
                shippingSectionParent?.classList.add('maison-section-highlight-error');
                showErrorInSection(shippingSectionParent, 'Выберите способ доставки');
                errors.push({ section: shippingSectionParent });
            }
        }

        const paymentSection = document.getElementById('maison-payment-section');
        const paymentRadio = paymentSection?.querySelector('input[name="payment_method"]:checked');
        if (!paymentRadio) {
            paymentSection?.closest('section')?.classList.add('maison-section-highlight-error');
            showErrorInSection(paymentSection, 'Выберите способ оплаты');
            errors.push({ section: paymentSection });
        }

        if (errors.length > 0) {
            const firstSection = errors[0].section;
            firstSection?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }

        const btn = document.getElementById('maison-confirm-order-btn');
        if (btn) btn.disabled = true;

        async function doConfirm() {
            try {
                const contactForm = document.querySelector('#maison-contact-form') || document.querySelector('#maison-contact-section form');
                if (contactForm) {
                    const fd = new FormData(contactForm);
                    if (shippingRequired) fd.set('shipping_address', '1');
                    const r1 = await fetchJson('checkout/maison_checkout/saveContact', fd);
                    if (r1.redirect) { window.location = r1.redirect; return; }
                    if (r1.error) {
                        showErrorInSection(contactSection, r1.error.warning || Object.values(r1.error || {}).join(' '));
                        btn.disabled = false;
                        return;
                    }
                }
                if (shippingRequired) {
                    let addrForm = document.querySelector('#maison-shipping-form') || document.querySelector('#maison-shipping-address-section form');
                    if (!addrForm) addrForm = document.querySelector('#maison-contact-form');
                    if (addrForm) {
                        const fd = new FormData(addrForm);
                        fd.set('maison', '1');
                        const r2 = await fetchJson('checkout/maison_checkout/saveShippingAddress', fd);
                        if (r2.redirect) { window.location = r2.redirect; return; }
                        if (r2.error) {
                            const shipSection = document.getElementById('maison-shipping-method-section')?.closest('section');
                            showErrorInSection(shipSection, r2.error.warning || Object.values(r2.error || {}).join(' '));
                            btn.disabled = false;
                            return;
                        }
                    }
                    const shipContainer = document.getElementById('maison-shipping-method-section');
                    const shipFd = new FormData();
                    const cr = shipContainer?.querySelector('input.maison-carrier-radio:checked');
                    const dt = shipContainer?.querySelector('input[name="delivery_type"]:checked');
                    if (cr && dt) shipFd.set('shipping_method', cr.value + '.' + dt.value);
                    const cmt = shipContainer?.querySelector('textarea[name="comment"]');
                    if (cmt) shipFd.set('comment', cmt.value);
                    const r3 = await fetchJson('checkout/shipping_method/save', shipFd);
                    if (r3.redirect) { window.location = r3.redirect; return; }
                    if (r3.error) {
                        showErrorInSection(shipContainer?.closest('section'), r3.error.warning || 'Ошибка доставки');
                        btn.disabled = false;
                        return;
                    }
                }
                const payContainer = document.getElementById('maison-payment-section');
                const payFd = new FormData();
                const pm = payContainer?.querySelector('input[name="payment_method"]:checked');
                if (pm) payFd.set('payment_method', pm.value);
                const agree = payContainer?.querySelector('input[name="agree"]');
                if (agree?.checked) payFd.set('agree', '1');
                const payCmt = payContainer?.querySelector('textarea[name="comment"]');
                if (payCmt) payFd.set('comment', payCmt.value);
                const r4 = await fetchJson('checkout/payment_method/save', payFd);
                if (r4.redirect) { window.location = r4.redirect; return; }
                if (r4.error) {
                    showErrorInSection(payContainer, r4.error.warning || 'Ошибка оплаты');
                    btn.disabled = false;
                    return;
                }
                if (pm && pm.value === 'bank_transfer') {
                    const urLicBlock = document.getElementById('maison-ur-lic-block');
                    urLicBlock?.querySelectorAll('.maison-section-error').forEach(el => el.remove());
                    urLicBlock?.classList.remove('hidden');
                    urLicBlock?.classList.add('flex');
                    document.getElementById('maison-confirm-section')?.classList.add('hidden');
                    document.getElementById('maison-contact-section-wrapper')?.classList.add('hidden');
                    document.getElementById('maison-shipping-section-wrapper')?.classList.add('hidden');
                    document.getElementById('maison-payment-section-wrapper')?.classList.add('hidden');
                    urLicBlock?.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    btn.disabled = false;
                    return;
                }
                const r5 = await fetch(baseUrl + 'checkout/maison_checkout/confirmOrder', { method: 'POST' }).then(res => res.json());
                if (r5.redirect) window.location = r5.redirect;
                else if (r5.error) {
                    showErrorInSection(document.getElementById('maison-confirm-section'), r5.error.warning || 'Ошибка подтверждения');
                    btn.disabled = false;
                }
            } catch (e) {
                console.error(e);
                btn.disabled = false;
            }
        }
        doConfirm();
    }

    document.addEventListener('DOMContentLoaded', function() {
        loadContactForm();
        initShippingMethodDebounce();
        initPaymentMethodDebounce();
        initPickupMapListeners();

        document.getElementById('maison-confirm-order-btn')?.addEventListener('click', function() {
            validateAndConfirmOrder();
        });

        document.getElementById('maison-ur-lic-back-btn')?.addEventListener('click', function() {
            document.getElementById('maison-ur-lic-block')?.classList.add('hidden');
            document.getElementById('maison-ur-lic-block')?.classList.remove('flex');
            document.getElementById('maison-confirm-section')?.classList.remove('hidden');
            document.getElementById('maison-contact-section-wrapper')?.classList.remove('hidden');
            document.getElementById('maison-shipping-section-wrapper')?.classList.remove('hidden');
            document.getElementById('maison-payment-section-wrapper')?.classList.remove('hidden');
        });

        document.getElementById('maison-ur-lic-submit-btn')?.addEventListener('click', async function() {
            const block = document.getElementById('maison-ur-lic-block');
            const btn = document.getElementById('maison-ur-lic-submit-btn');
            const fd = new FormData();
            block?.querySelectorAll('input[name^="ur_"]').forEach(function(inp) {
                if (inp.name) fd.set(inp.name, inp.value || '');
            });
            try {
                btn.disabled = true;
                const r = await fetch(baseUrl + 'checkout/maison_checkout/saveUrLic', { method: 'POST', body: fd }).then(res => res.json());
                if (r.redirect) window.location = r.redirect;
                else if (r.error) {
                    showErrorInSection(block, r.error.warning || 'Ошибка сохранения');
                    btn.disabled = false;
                }
            } catch (e) {
                console.error(e);
                btn.disabled = false;
            }
        });

        document.getElementById('maison-coupon-btn')?.addEventListener('click', async function() {
            const input = document.getElementById('maison-coupon-input');
            const code = input?.value?.trim();
            if (!code) return;
            try {
                const formData = new FormData();
                formData.set('coupon', code);
                const res = await fetch('{{ coupon_action }}', { method: 'POST', body: formData });
                const json = await res.json();
                if (json.error) alert(json.error);
                else if (json.redirect) location.reload();
            } catch (e) {
                alert('Ошибка: ' + e.message);
            }
        });
    });
})();
</script>
