</div>

<script>
(function() {
    const base = '{{ base }}';
    const baseUrl = base + 'index.php?route=';
    const shippingRequired = {{ shipping_required ? 'true' : 'false' }};
    const logged = {{ logged ? 'true' : 'false' }};
    const dadataToken = {{ dadata_token|json_encode|raw }};

    function showError(container, message) {
        container.innerHTML = '<div class="rounded-md border border-red-100 bg-red-50 px-4 py-3 text-sm text-red-900">' + message + '</div>';
    }

    function showErrorInSection(container, message) {
        let err = container.querySelector('.maison-section-error');
        if (!err) {
            err = document.createElement('div');
            err.className = 'maison-section-error mb-4 rounded-md border border-red-100 bg-red-50 px-4 py-3 text-sm text-red-900';
            container.insertBefore(err, container.firstChild);
        }
        err.innerHTML = message || '';
        err.style.display = message ? 'block' : 'none';
    }

    function showLoading(container, text) {
        container.innerHTML = '<div class="flex justify-center py-4 text-gray-400"><span class="animate-pulse">' + (text || 'Загрузка...') + '</span></div>';
    }

    async function fetchHtml(route) {
        const res = await fetch(baseUrl + route);
        if (!res.ok) throw new Error(res.statusText);
        return res.text();
    }

    async function fetchJson(route, formData) {
        const res = await fetch(baseUrl + route, {
            method: 'POST',
            body: formData
        });
        const text = await res.text();
        try {
            return JSON.parse(text);
        } catch {
            throw new Error(text || 'Invalid response');
        }
    }

    function collectFormData(selector) {
        const form = document.querySelector(selector);
        if (!form) return new FormData();
        return new FormData(form);
    }

    function debounce(fn, ms) {
        let t;
        return function() {
            clearTimeout(t);
            t = setTimeout(() => fn.apply(this, arguments), ms);
        };
    }

    async function loadContactForm() {
        const container = document.getElementById('maison-contact-section');
        const shippingSection = document.getElementById('maison-shipping-address-section');
        try {
            const route = 'checkout/guest&maison=1';
            const html = await fetchHtml(route);
            const wrapper = document.createElement('div');
            wrapper.innerHTML = html;
            const form = wrapper.querySelector('form');
            const addressPart = wrapper.querySelector('#maison-guest-address-part');
            if (form) {
                form.id = 'maison-contact-form';
                if (addressPart && shippingRequired && shippingSection) {
                    addressPart.querySelector('input')?.setAttribute('form', 'maison-contact-form');
                    shippingSection.appendChild(addressPart);
                } else if (addressPart && !shippingRequired) {
                    addressPart.querySelector('input')?.removeAttribute('form');
                    form.appendChild(addressPart);
                }
                container.innerHTML = '';
                container.appendChild(form);
                initCountrySelect(container);
                initContactDebounce();
                initDaDataAddress();
            } else {
                container.innerHTML = html;
                const f = container.querySelector('form');
                if (f) {
                    f.id = 'maison-contact-form';
                    const btn = f.querySelector('#button-guest') || f.querySelector('#button-payment-address') || f.querySelector('[type="submit"]');
                    if (btn) btn.style.display = 'none';
                    initCountrySelect(container);
                    initContactDebounce();
                    initDaDataAddress();
                }
            }
        } catch (e) {
            showError(container, 'Ошибка загрузки формы: ' + e.message);
        }
    }

    function initDaDataAddress() {
        if (!dadataToken || typeof Dadata === 'undefined') return;
        const addressPart = document.getElementById('maison-guest-address-part');
        if (!addressPart || addressPart.dataset.dadataInit) return;
        const input = addressPart.querySelector('#input-payment-address-1');
        if (!input) return;
        addressPart.dataset.dadataInit = '1';
        try {
            Dadata.createSuggestions(input, {
                token: dadataToken,
                type: 'address',
                onSelect: function(suggestion) {
                    const cityEl = document.querySelector('#input-payment-city');
                    const postcodeEl = document.querySelector('input[name="postcode"]');
                    if (cityEl && suggestion.data?.city) cityEl.value = suggestion.data.city;
                    if (postcodeEl && suggestion.data?.postal_code) postcodeEl.value = suggestion.data.postal_code;
                    saveShippingAddress();
                }
            });
        } catch (e) {
            console.error('DaData init error:', e);
        }
    }

    function initContactDebounce() {
        const form = document.querySelector('#maison-contact-form') || document.querySelector('#maison-contact-section form');
        if (!form || form.dataset.debounceInit) return;
        form.dataset.debounceInit = '1';
        if (logged) {
            const debouncedSave = debounce(saveContact, 600);
            form.querySelectorAll('input, select').forEach(el => {
                el.addEventListener('input', debouncedSave);
                el.addEventListener('change', debouncedSave);
            });
            document.getElementById('maison-checkout')?.querySelectorAll('input[name="address_1"], #input-payment-address-1, #input-shipping-address-1').forEach(el => {
                el.addEventListener('input', clearAddressError);
                el.addEventListener('change', clearAddressError);
            });
            return;
        }
        const debouncedSaveCustomer = debounce(saveCustomer, 1500);
        const debouncedSaveAddress = debounce(saveShippingAddress, 1200);
        form.querySelectorAll('input[name="firstname"], input[name="lastname"], input[name="email"], input[name="telephone"]').forEach(el => {
            el.addEventListener('input', debouncedSaveCustomer);
        });
        const checkoutEl = document.getElementById('maison-checkout');
        if (checkoutEl) {
            checkoutEl.querySelectorAll('input[name="address_1"], input[name="city"], input[name="postcode"]').forEach(el => {
                el.addEventListener('input', debouncedSaveAddress);
                el.addEventListener('input', clearAddressError);
                el.addEventListener('change', clearAddressError);
            });
        // checkoutEl.querySelectorAll('select[name="country_id"], select[name="zone_id"]').forEach(el => {
        //         el.addEventListener('change', debouncedSaveAddress);
        //     });
        }
    }

    function initCountrySelect(container) {
        const countrySelect = container.querySelector('select[name="country_id"]');
        if (!countrySelect) return;
        countrySelect.addEventListener('change', async function() {
            const zoneSelect = container.querySelector('select[name="zone_id"]');
            if (!zoneSelect) return;
            try {
                const json = await fetch(baseUrl + 'checkout/checkout/country&country_id=' + this.value).then(r => r.json());
                let html = '<option value="">Выберите</option>';
                if (json.zone && json.zone.length) {
                    json.zone.forEach(z => {
                        html += '<option value="' + z.zone_id + '">' + z.name + '</option>';
                    });
                } else {
                    html += '<option value="0" selected>—</option>';
                }
                zoneSelect.innerHTML = html;
            } catch (e) {
                console.error(e);
            }
        });
        if (countrySelect.value) countrySelect.dispatchEvent(new Event('change'));
    }

