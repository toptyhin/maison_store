                                            Закрыть
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="bg-gray-50 rounded-md p-4 flex items-start gap-4 border border-gray-200/60">
                            <div class="bg-white p-2 rounded-full border border-gray-100 shadow-sm text-luxury-charcoal">
                                <span class="material-symbols-outlined text-[20px] block">schedule</span>
                            </div>
