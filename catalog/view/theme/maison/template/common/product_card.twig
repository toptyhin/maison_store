                        <div class="flex flex-col gap-5 group relative">
                            <a href="{{ product.href }}" class="absolute inset-0 z-10" aria-label="Перейти к {{ product.name }}"></a>
                            <div class="absolute top-4 right-4 z-20">
                                <button type="button"
                                    class="product-favorite-btn bg-white flex items-center justify-center size-9 rounded-full {% if product.in_wishlist|default(false) %}text-discount-red{% else %}text-luxury-charcoal hover:bg-white hover:text-discount-red{% endif %} transition-all duration-300 shadow-sm group/heart"
                                    data-product-id="{{ product.product_id }}"
                                    title="{% if product.in_wishlist|default(false) %}Удалить из избранного{% else %}Добавить в избранное{% endif %}">
                                    <span
                                        class="material-symbols-outlined text-[20px] font-medium group-hover/heart:font-variation-settings-'FILL'-1"
                                        {% if product.in_wishlist|default(false) %}style="font-variation-settings: 'FILL' 1"{% endif %}>favorite</span>
                                </button>
                            </div>
                            <div
                                class="relative aspect-[3/4] overflow-hidden rounded-sm bg-white shadow-soft border border-gray-200 group-hover:border-primary/30 transition-colors duration-500">
                                <img alt="{{ product.name }}"
                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-95 group-hover:opacity-100"
                                    src="{{ product.thumb }}" />
                                <div
                                    class="absolute top-4 left-4 bg-badge-gold text-white backdrop-blur-md px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest shadow-sm">
                                    ЭКСКЛЮЗИВ</div>
                                <div
                                    class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                                    <span
                                        class="w-full bg-[#263238] block text-center text-white border border-[#263238] py-4 font-bold uppercase text-xs tracking-widest hover:bg-[#455A64] hover:border-[#455A64] transition-all duration-300 shadow-lg">
                                        Подробнее
                                    </span>
                                </div>
                            </div>
                            <div class="flex flex-col gap-2 p-2">
                                <h4
                                    class="font-serif text-xl text-luxury-charcoal hover:text-primary transition-colors cursor-pointer">
                                    {{ product.name }}</h4>
                                <p class="text-gray-500 text-xs uppercase tracking-widest">Сатин, 800 нитей</p>
                                {% if product.rating %}
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="material-symbols-outlined text-[16px] text-primary"
                                        style="font-variation-settings: 'FILL' 1;">star</span>
                                    <span class="text-luxury-charcoal font-bold text-sm">{{ product.rating }}</span>
                                    {% if product.reviews %}
                                        <span class="text-gray-400 text-sm">({{ product.reviews }} отзывов)</span>
                                    {% endif %}
                                </div>
                                {% endif %}
								{% if product.price %}
									{% if not product.special %}
										<p class="font-bold text-luxury-charcoal mt-1 text-lg">От {{ product.price }}</p>
									{% else %}
										<div class="flex flex-wrap items-center gap-2 mt-1">
                                            <p class="font-bold text-luxury-charcoal text-lg">От {{ product.special }}</p>
											<p class="text-discount-red line-through decoration-2 text-sm">{{ product.price }}</p>
											
											{% if product.discount_percent %}
											<span
												class="bg-badge-pink-bg text-badge-pink-text px-2 py-0.5 rounded-lg text-sm font-bold">-{{ product.discount_percent }}%</span>
											{% endif %}
										</div>								
									{% endif %}
								{% endif %}
                            </div>
                        </div>