{% if cookie_info %}
	<div class="fixed bottom-0 left-0 right-0 z-[100] bg-[#263238]/95 backdrop-blur-sm border-t border-white/10 shadow-[0_-4px_20px_rgba(0,0,0,0.15)] transform transition-transform duration-500" id="cookie-consent">
  		<div class="max-w-7xl mx-auto px-6 lg:px-12 py-6 flex flex-col md:flex-row items-center justify-between gap-6">
			<p class="text-white/90 text-sm font-light leading-relaxed text-center md:text-left max-w-3xl">
				{{ cookie_info|raw }}
			</p>
			<div class="flex items-center gap-6 shrink-0">
				{# <button type="button" class="cookie-consent-settings text-xs font-bold text-gray-300 hover:text-white underline uppercase tracking-widest transition-colors">
					Настройки
				</button> #}
				<button type="button" id="accept-cookie" class="bg-white text-[#263238] hover:bg-gray-200 transition-colors px-8 py-3 text-xs font-bold uppercase tracking-widest rounded-sm shadow-sm min-w-[140px]">
					{{ button_continue }}
				</button>
			</div>
		</div>
	</div>
	<script>
		(function() {
			var el = document.getElementById('cookie-consent');
			var acceptBtn = document.getElementById('accept-cookie');
			if (!el || !acceptBtn) return;
			acceptBtn.addEventListener('click', function() {
				fetch('index.php?route=common/footer/applyCookieNotification');
				el.style.transform = 'translateY(100%)';
			});
		})();
	</script>
{% endif %}
