{{ header }}
<main class="flex-1 mt-24">
  {{ content_top }}
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
    <nav class="mb-8">
      <ol class="flex flex-wrap items-center gap-2 text-sm">
        {% for breadcrumb in breadcrumbs %}
          <li class="flex items-center gap-2">
            {% if not loop.first %}
              <span class="text-gray-300">/</span>
            {% endif %}
            {% if loop.last %}
              <span class="text-gray-500 font-medium">{{ breadcrumb.text }}</span>
            {% else %}
              <a href="{{ breadcrumb.href }}" class="text-gray-500 hover:text-luxury-charcoal transition-colors">{{ breadcrumb.text }}</a>
            {% endif %}
          </li>
        {% endfor %}
      </ol>
    </nav>

    <h1 class="text-4xl md:text-5xl font-serif text-luxury-charcoal font-medium mb-10">{{ heading_title }}</h1>

    {% if error_agree %}
      <div class="mb-6 rounded-md border border-red-100 bg-red-50 px-4 py-3 text-sm text-red-900 flex items-start gap-2">
        <span class="material-symbols-outlined text-[18px] mt-0.5 shrink-0">error</span>
        <div class="flex-1">{{ error_agree }}</div>
      </div>
    {% endif %}

    {# Контактная информация #}
    <section class="mb-12">
      <h2 class="text-xl font-serif font-medium text-luxury-charcoal mb-6">{{ text_location }}</h2>
      <div class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-full pointer-events-none"></div>
        <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 {% if image %}lg:grid-cols-4{% else %}lg:grid-cols-3{% endif %} gap-8">
          {% if image %}
            <div>
              <img src="{{ image }}" alt="{{ store }}" title="{{ store }}" class="rounded-sm w-full object-cover border border-gray-100" />
            </div>
          {% endif %}
          <div class="space-y-1">
            <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ store }}</strong>
            <address class="text-gray-600 text-sm leading-relaxed not-italic">
              {{ address|raw }}
            </address>
            {% if geocode %}
              <a href="https://maps.google.com/maps?q={{ geocode|url_encode }}&hl={{ geocode_hl }}&t=m&z=15" target="_blank" class="inline-flex items-center gap-2 mt-3 text-primary text-sm font-medium hover:text-primary-dark transition-colors">
                <span class="material-symbols-outlined text-[18px]">map</span>
                {{ button_map }}
              </a>
            {% endif %}
          </div>
          <div class="space-y-1">
            <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ text_telephone }}</strong>
            <p class="text-gray-600 text-sm">{{ telephone }}</p>
            {% if fax %}
              <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ text_fax }}</strong>
              <p class="text-gray-600 text-sm">{{ fax }}</p>
            {% endif %}
          </div>
          <div class="space-y-1">
            {% if open %}
              <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ text_open }}</strong>
              <p class="text-gray-600 text-sm">{{ open|raw }}</p>
            {% endif %}
            {% if comment %}
              <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ text_comment }}</strong>
              <p class="text-gray-600 text-sm">{{ comment|raw }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    </section>

    {% if locations %}
    <section class="mb-12">
      <h2 class="text-xl font-serif font-medium text-luxury-charcoal mb-6">{{ text_store }}</h2>
      <div class="space-y-3">
        {% for location in locations %}
        <details class="group bg-white rounded-lg shadow-soft border border-gray-100 overflow-hidden">
          <summary class="flex items-center justify-between cursor-pointer list-none px-6 py-4 hover:bg-gray-50 transition-colors">
            <span class="font-medium text-luxury-charcoal">{{ location.name }}</span>
            <span class="material-symbols-outlined text-gray-400 group-open:rotate-180 transition-transform">expand_more</span>
          </summary>
          <div class="px-6 pb-6 pt-0 border-t border-gray-100">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 pt-6">
              {% if location.image %}
                <div class="lg:col-span-1">
                  <img src="{{ location.image }}" alt="{{ location.name }}" title="{{ location.name }}" class="rounded-sm w-full object-cover border border-gray-100" />
                </div>
              {% endif %}
              <div class="space-y-1">
                <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ location.name }}</strong>
                <address class="text-gray-600 text-sm leading-relaxed not-italic">
                  {{ location.address|raw }}
                </address>
                {% if location.geocode %}
                  <a href="https://maps.google.com/maps?q={{ location.geocode|url_encode }}&hl={{ geocode_hl }}&t=m&z=15" target="_blank" class="inline-flex items-center gap-2 mt-3 text-primary text-sm font-medium hover:text-primary-dark transition-colors">
                    <span class="material-symbols-outlined text-[18px]">map</span>
                    {{ button_map }}
                  </a>
                {% endif %}
              </div>
              <div class="space-y-1">
                <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ text_telephone }}</strong>
                <p class="text-gray-600 text-sm">{{ location.telephone }}</p>
                {% if location.fax %}
                  <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ text_fax }}</strong>
                  <p class="text-gray-600 text-sm">{{ location.fax }}</p>
                {% endif %}
              </div>
              <div class="space-y-1">
                {% if location.open %}
                  <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ text_open }}</strong>
                  <p class="text-gray-600 text-sm">{{ location.open|raw }}</p>
                {% endif %}
                {% if location.comment %}
                  <strong class="text-luxury-charcoal font-medium text-sm uppercase tracking-widest">{{ text_comment }}</strong>
                  <p class="text-gray-600 text-sm">{{ location.comment|raw }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        </details>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {# Форма обратной связи #}
    <section class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-full pointer-events-none"></div>
      <div class="relative z-10 max-w-2xl">
        <h2 class="text-xl font-serif font-medium text-luxury-charcoal mb-6">{{ text_contact }}</h2>
        <form action="{{ action }}" method="post" enctype="multipart/form-data" class="flex flex-col gap-5">
          <div>
            <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2" for="input-name">{{ entry_name }}</label>
            <input type="text" name="name" value="{{ name }}" id="input-name" class="w-full rounded-sm border border-gray-200 bg-gray-50 py-3 px-4 text-sm text-luxury-charcoal focus:border-luxury-charcoal focus:ring-0 focus:bg-white placeholder:text-gray-400 transition-colors" />
            {% if error_name %}
              <p class="text-red-500 text-xs mt-1.5">{{ error_name }}</p>
            {% endif %}
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2" for="input-email">{{ entry_email }}</label>
            <input type="text" name="email" value="{{ email }}" id="input-email" class="w-full rounded-sm border border-gray-200 bg-gray-50 py-3 px-4 text-sm text-luxury-charcoal focus:border-luxury-charcoal focus:ring-0 focus:bg-white placeholder:text-gray-400 transition-colors" />
            {% if error_email %}
              <p class="text-red-500 text-xs mt-1.5">{{ error_email }}</p>
            {% endif %}
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2" for="input-enquiry">{{ entry_enquiry }}</label>
            <textarea name="enquiry" rows="6" id="input-enquiry" class="w-full rounded-sm border border-gray-200 bg-gray-50 py-3 px-4 text-sm text-luxury-charcoal focus:border-luxury-charcoal focus:ring-0 focus:bg-white placeholder:text-gray-400 transition-colors resize-none">{{ enquiry }}</textarea>
            {% if error_enquiry %}
              <p class="text-red-500 text-xs mt-1.5">{{ error_enquiry }}</p>
            {% endif %}
          </div>
          {{ captcha }}
          {% if text_agree %}
            <div class="flex items-start gap-3">
              <input type="checkbox" name="agree" value="1" {% if agree %}checked{% endif %} class="mt-0.5 rounded-sm border-gray-300 text-luxury-charcoal focus:ring-luxury-charcoal/30 cursor-pointer" id="input-agree" />
              <label class="text-xs text-gray-500 leading-snug cursor-pointer select-none" for="input-agree">
                {{ text_agree|raw }}
              </label>
            </div>
          {% endif %}
          <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-luxury-charcoal text-white border border-transparent px-8 py-4 rounded-sm text-xs font-bold uppercase tracking-[0.15em] hover:bg-primary-dark transition-colors shadow-sm">
            {{ button_submit }}
            <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
          </button>
        </form>
      </div>
    </section>
  </div>
  {{ content_bottom }}
</main>
{{ footer }}
