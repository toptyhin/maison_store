{{ header }}
<main class="flex-1 mt-24">
	{{ content_top }}
	<div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
		<div class="flex-1" id="special-products">
			<div class="mb-10">
				<h1 class="text-4xl md:text-5xl font-serif text-luxury-charcoal font-medium">{{ heading_title }}</h1>
			</div>
			{% if products %}
				<div class="flex items-center justify-between mb-8" id="special-products-header">
					<p class="text-gray-500 text-sm">Показано {{ product_shown }} из {{ product_total }} товаров</p>
					<div class="flex items-center gap-2">
						<span class="text-xs font-bold uppercase tracking-widest text-luxury-charcoal">Сортировка:</span>
						<select class="bg-transparent border-none text-sm text-gray-600 focus:ring-0 cursor-pointer py-0 pr-8 pl-1" onchange="location = this.value;">
							{% for sorts in sorts %}
								{% if sorts.value == '%s-%s'|format(sort, order) %}
									<option value="{{ sorts.href }}" selected="selected">{{ sorts.text }}</option>
								{% else %}
									<option value="{{ sorts.href }}">{{ sorts.text }}</option>
								{% endif %}
							{% endfor %}
						</select>
					</div>
				</div>
				<div id="special-products-grid" class="relative">
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
						{% for product in products %}
							{{ include('maison/template/common/product_card.twig', { product: product }) }}
						{% endfor %}
					</div>
				</div>
				<div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-12 pt-8 border-t border-gray-200">
					<div class="text-gray-500 text-sm">{{ results }}</div>
					<div>{{ pagination }}</div>
				</div>
			{% else %}
				<div id="special-products-grid" class="relative">
					<div class="flex flex-col items-center justify-center py-16">
						<p class="text-gray-500 text-sm text-center mb-6">{{ text_empty }}</p>
						<a href="{{ continue }}" class="inline-block bg-luxury-charcoal text-white px-8 py-3 font-bold uppercase text-xs tracking-widest hover:bg-primary transition-colors">{{ button_continue }}</a>
					</div>
				</div>
			{% endif %}
		</div>
	</div>
</main>
{{ footer }}
