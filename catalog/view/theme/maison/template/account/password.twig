{{ header }}
<main class="flex-1 bg-background-dark">
	{{ include('maison/template/account/account_header.twig') }}
	<div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
		<div class="flex flex-col lg:flex-row gap-8">
			{{ menu }}
			<div class="flex-1 min-w-0">
				{{ content_top }}
				<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
					<div>
						<h1 class="text-3xl font-serif text-luxury-charcoal font-medium">{{ heading_title }}</h1>
						<p class="text-gray-500 mt-1 text-sm">Измените пароль для защиты вашего аккаунта</p>
					</div>
				</div>
				<div class="bg-white rounded-lg shadow-soft border border-gray-100 overflow-hidden">
					<div class="p-8">
						<form action="{{ action }}" method="post" enctype="multipart/form-data" class="space-y-8">
							<div>
								<h2 class="text-lg font-serif text-luxury-charcoal font-bold mb-6 pb-2 border-b border-gray-100">{{ text_password }}</h2>
								<div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
									<div class="space-y-1 md:col-span-2">
										<label class="block text-xs font-bold uppercase text-gray-500 tracking-wider" for="input-password">{{ entry_password }}</label>
										<input class="block w-full rounded-sm border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm py-3 px-4 bg-gray-50/50 {% if error_password %}border-red-500{% endif %}" id="input-password" name="password" type="password" value="{{ password }}" placeholder="{{ entry_password }}" autocomplete="new-password"/>
										{% if error_password %}
											<p class="text-red-500 text-xs mt-1">{{ error_password }}</p>
										{% endif %}
									</div>
									<div class="space-y-1 md:col-span-2">
										<label class="block text-xs font-bold uppercase text-gray-500 tracking-wider" for="input-confirm">{{ entry_confirm }}</label>
										<input class="block w-full rounded-sm border-gray-300 shadow-sm focus:border-primary focus:ring-primary sm:text-sm py-3 px-4 bg-gray-50/50 {% if error_confirm %}border-red-500{% endif %}" id="input-confirm" name="confirm" type="password" value="{{ confirm }}" placeholder="{{ entry_confirm }}" autocomplete="new-password"/>
										{% if error_confirm %}
											<p class="text-red-500 text-xs mt-1">{{ error_confirm }}</p>
										{% endif %}
									</div>
								</div>
							</div>
							<div class="flex flex-col sm:flex-row gap-4 pt-2">
								<a href="{{ back }}" class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-gray-300 text-luxury-charcoal text-sm font-bold uppercase tracking-widest hover:bg-gray-50 transition-colors rounded-sm">
									<span class="material-symbols-outlined text-[20px]">arrow_back</span>
									{{ button_back }}
								</a>
								<button class="w-full sm:w-auto px-8 py-4 bg-[#263238] text-white text-sm font-bold uppercase tracking-widest hover:bg-primary-dark transition-all duration-300 shadow-lg hover:shadow-xl rounded-sm" type="submit">
									{{ button_continue }}
								</button>
							</div>
						</form>
					</div>
				</div>
				{{ content_bottom }}
			</div>
		</div>
	</div>
</main>
{{ footer }}
