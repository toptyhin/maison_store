{{ header }}
<main class="flex-1 bg-background-dark mt-24">
{{ include('maison/template/account/account_header.twig') }}
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
    {% if success %}
    <div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800 flex items-center gap-2">
      <span class="material-symbols-outlined text-[20px]">check_circle</span>
      {{ success }}
    </div>
    {% endif %}
    {% if error_warning %}
    <div class="mb-6 rounded-lg bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800 flex items-center gap-2">
      <span class="material-symbols-outlined text-[20px]">warning</span>
      {{ error_warning }}
    </div>
    {% endif %}
    <div class="flex flex-col lg:flex-row gap-8">
      {{ menu }}
      <div class="flex-1 min-w-0">
        {{ content_top }}
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
          <div>
            <h1 class="text-3xl font-serif text-luxury-charcoal font-medium">{{ text_address }}</h1>
            <p class="text-gray-500 mt-1 text-sm">{{ text_address_book }}</p>
          </div>
          <a href="{{ back }}" class="inline-flex items-center gap-2 text-primary hover:text-luxury-charcoal transition-colors text-sm font-medium">
            <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            {{ button_back }}
          </a>
        </div>

        {% set input_class = 'w-full rounded-sm border border-gray-200 bg-gray-50 py-3 px-4 text-sm text-luxury-charcoal focus:border-luxury-charcoal focus:ring-0 focus:bg-white placeholder:text-gray-400 transition-colors' %}
        {% set label_class = 'block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2' %}
        {% set error_class = 'mt-1.5 text-xs text-red-600' %}

        <div class="bg-white rounded-lg shadow-soft border border-gray-100 overflow-hidden mb-6">
          <div class="p-6 border-b border-gray-100">
            <h2 class="text-lg font-serif text-luxury-charcoal font-bold">{{ text_address }}</h2>
          </div>
          <form action="{{ action }}" method="post" enctype="multipart/form-data" class="p-6">
            <div class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="form-group">
                  <label class="{{ label_class }}" for="input-firstname">{{ entry_firstname }} <span class="text-red-500">*</span></label>
                  <input type="text" name="firstname" value="{{ firstname }}" placeholder="{{ entry_firstname }}" id="input-firstname" class="{{ input_class }}{% if error_firstname %} border-red-300{% endif %}" />
                  {% if error_firstname %}<p class="{{ error_class }}">{{ error_firstname }}</p>{% endif %}
                </div>
                <div class="form-group">
                  <label class="{{ label_class }}" for="input-lastname">{{ entry_lastname }} <span class="text-red-500">*</span></label>
                  <input type="text" name="lastname" value="{{ lastname }}" placeholder="{{ entry_lastname }}" id="input-lastname" class="{{ input_class }}{% if error_lastname %} border-red-300{% endif %}" />
                  {% if error_lastname %}<p class="{{ error_class }}">{{ error_lastname }}</p>{% endif %}
                </div>
              </div>

              <div class="form-group">
                <label class="{{ label_class }}" for="input-company">{{ entry_company }}</label>
                <input type="text" name="company" value="{{ company }}" placeholder="{{ entry_company }}" id="input-company" class="{{ input_class }}" />
              </div>

              <div class="form-group">
                <label class="{{ label_class }}" for="input-address-1">{{ entry_address_1 }} <span class="text-red-500">*</span></label>
                <input type="text" name="address_1" value="{{ address_1 }}" placeholder="{{ entry_address_1 }}" id="input-address-1" class="{{ input_class }}{% if error_address_1 %} border-red-300{% endif %}" />
                {% if error_address_1 %}<p class="{{ error_class }}">{{ error_address_1 }}</p>{% endif %}
              </div>

              <div class="form-group">
                <label class="{{ label_class }}" for="input-address-2">{{ entry_address_2 }}</label>
                <input type="text" name="address_2" value="{{ address_2 }}" placeholder="{{ entry_address_2 }}" id="input-address-2" class="{{ input_class }}" />
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="form-group">
                  <label class="{{ label_class }}" for="input-city">{{ entry_city }} <span class="text-red-500">*</span></label>
                  <input type="text" name="city" value="{{ city }}" placeholder="{{ entry_city }}" id="input-city" class="{{ input_class }}{% if error_city %} border-red-300{% endif %}" />
                  {% if error_city %}<p class="{{ error_class }}">{{ error_city }}</p>{% endif %}
                </div>
                <div class="form-group">
                  <label class="{{ label_class }}" for="input-postcode">{{ entry_postcode }} <span class="text-red-500">*</span></label>
                  <input type="text" name="postcode" value="{{ postcode }}" placeholder="{{ entry_postcode }}" id="input-postcode" class="{{ input_class }}{% if error_postcode %} border-red-300{% endif %}" />
                  {% if error_postcode %}<p class="{{ error_class }}">{{ error_postcode }}</p>{% endif %}
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="form-group">
                  <label class="{{ label_class }}" for="input-country">{{ entry_country }} <span class="text-red-500">*</span></label>
                  <select name="country_id" id="input-country" class="{{ input_class }}{% if error_country %} border-red-300{% endif %}">
                    <option value="">{{ text_select }}</option>
                    {% for country in countries %}
                    <option value="{{ country.country_id }}" {{ country.country_id == country_id ? 'selected' : '' }}>{{ country.name }}</option>
                    {% endfor %}
                  </select>
                  {% if error_country %}<p class="{{ error_class }}">{{ error_country }}</p>{% endif %}
                </div>
                <div class="form-group">
                  <label class="{{ label_class }}" for="input-zone">{{ entry_zone }} <span class="text-red-500">*</span></label>
                  <select name="zone_id" id="input-zone" class="{{ input_class }}{% if error_zone %} border-red-300{% endif %}">
                  </select>
                  {% if error_zone %}<p class="{{ error_class }}">{{ error_zone }}</p>{% endif %}
                </div>
              </div>

              {% for custom_field in custom_fields %}
              {% if custom_field.type == 'select' %}
              <div class="form-group{% if custom_field.required %} required{% endif %} custom-field" data-sort="{{ custom_field.sort_order }}">
                <label class="{{ label_class }}" for="input-custom-field{{ custom_field.custom_field_id }}">{{ custom_field.name }}{% if custom_field.required %} <span class="text-red-500">*</span>{% endif %}</label>
                <select name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" id="input-custom-field{{ custom_field.custom_field_id }}" class="{{ input_class }}">
                  <option value="">{{ text_select }}</option>
                  {% for custom_field_value in custom_field.custom_field_value %}
                  <option value="{{ custom_field_value.custom_field_value_id }}" {{ address_custom_field[custom_field.custom_field_id] and custom_field_value.custom_field_value_id == address_custom_field[custom_field.custom_field_id] ? 'selected' : '' }}>{{ custom_field_value.name }}</option>
                  {% endfor %}
                </select>
                {% if error_custom_field[custom_field.custom_field_id] %}<p class="{{ error_class }}">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
              </div>
              {% endif %}
              {% if custom_field.type == 'radio' %}
              <div class="form-group{% if custom_field.required %} required{% endif %} custom-field" data-sort="{{ custom_field.sort_order }}">
                <label class="{{ label_class }}">{{ custom_field.name }}{% if custom_field.required %} <span class="text-red-500">*</span>{% endif %}</label>
                <div class="flex flex-wrap gap-4 pt-2">
                  {% for custom_field_value in custom_field.custom_field_value %}
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" value="{{ custom_field_value.custom_field_value_id }}" {{ address_custom_field[custom_field.custom_field_id] and custom_field_value.custom_field_value_id == address_custom_field[custom_field.custom_field_id] ? 'checked' : '' }} class="rounded border-gray-300 text-primary focus:ring-luxury-charcoal" />
                    <span class="text-sm text-luxury-charcoal">{{ custom_field_value.name }}</span>
                  </label>
                  {% endfor %}
                </div>
                {% if error_custom_field[custom_field.custom_field_id] %}<p class="{{ error_class }}">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
              </div>
              {% endif %}
              {% if custom_field.type == 'checkbox' %}
              <div class="form-group{% if custom_field.required %} required{% endif %} custom-field" data-sort="{{ custom_field.sort_order }}">
                <label class="{{ label_class }}">{{ custom_field.name }}{% if custom_field.required %} <span class="text-red-500">*</span>{% endif %}</label>
                <div class="flex flex-wrap gap-4 pt-2">
                  {% for custom_field_value in custom_field.custom_field_value %}
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}][]" value="{{ custom_field_value.custom_field_value_id }}" {{ address_custom_field[custom_field.custom_field_id] and custom_field_value.custom_field_value_id in address_custom_field[custom_field.custom_field_id] ? 'checked' : '' }} class="rounded border-gray-300 text-primary focus:ring-luxury-charcoal" />
                    <span class="text-sm text-luxury-charcoal">{{ custom_field_value.name }}</span>
                  </label>
                  {% endfor %}
                </div>
                {% if error_custom_field[custom_field.custom_field_id] %}<p class="{{ error_class }}">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
              </div>
              {% endif %}
              {% if custom_field.type == 'text' %}
              <div class="form-group{% if custom_field.required %} required{% endif %} custom-field" data-sort="{{ custom_field.sort_order }}">
                <label class="{{ label_class }}" for="input-custom-field{{ custom_field.custom_field_id }}">{{ custom_field.name }}{% if custom_field.required %} <span class="text-red-500">*</span>{% endif %}</label>
                <input type="text" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" value="{% if address_custom_field[custom_field.custom_field_id] %}{{ address_custom_field[custom_field.custom_field_id] }}{% else %}{{ custom_field.value }}{% endif %}" placeholder="{{ custom_field.name }}" id="input-custom-field{{ custom_field.custom_field_id }}" class="{{ input_class }}" />
                {% if error_custom_field[custom_field.custom_field_id] %}<p class="{{ error_class }}">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
              </div>
              {% endif %}
              {% if custom_field.type == 'textarea' %}
              <div class="form-group{% if custom_field.required %} required{% endif %} custom-field" data-sort="{{ custom_field.sort_order }}">
                <label class="{{ label_class }}" for="input-custom-field{{ custom_field.custom_field_id }}">{{ custom_field.name }}{% if custom_field.required %} <span class="text-red-500">*</span>{% endif %}</label>
                <textarea name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" rows="5" placeholder="{{ custom_field.name }}" id="input-custom-field{{ custom_field.custom_field_id }}" class="{{ input_class }}">{{ address_custom_field[custom_field.custom_field_id]|default(custom_field.value) }}</textarea>
                {% if error_custom_field[custom_field.custom_field_id] %}<p class="{{ error_class }}">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
              </div>
              {% endif %}
              {% if custom_field.type == 'file' %}
              <div class="form-group{% if custom_field.required %} required{% endif %} custom-field" data-sort="{{ custom_field.sort_order }}">
                <label class="{{ label_class }}">{{ custom_field.name }}{% if custom_field.required %} <span class="text-red-500">*</span>{% endif %}</label>
                <div class="flex items-center gap-3 pt-2">
                  <button type="button" id="button-custom-field{{ custom_field.custom_field_id }}" data-loading-text="{{ text_loading }}" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-sm border border-gray-200 bg-gray-50 text-sm font-medium text-luxury-charcoal hover:bg-gray-100 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">upload</span>
                    {{ button_upload }}
                  </button>
                  <input type="hidden" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" value="{% if address_custom_field[custom_field.custom_field_id]['code'] %}{{ address_custom_field[custom_field.custom_field_id]['code'] }}{% endif %}" />
                  <span class="text-sm text-gray-500">{{ address_custom_field[custom_field.custom_field_id]['name']|default('') }}</span>
                </div>
                {% if error_custom_field[custom_field.custom_field_id] %}<p class="{{ error_class }}">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
              </div>
              {% endif %}
              {% if custom_field.type == 'date' %}
              <div class="form-group{% if custom_field.required %} required{% endif %} custom-field" data-sort="{{ custom_field.sort_order }}">
                <label class="{{ label_class }}" for="input-custom-field{{ custom_field.custom_field_id }}">{{ custom_field.name }}{% if custom_field.required %} <span class="text-red-500">*</span>{% endif %}</label>
                <div class="input-group date flex">
                  <input type="text" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" value="{% if address_custom_field[custom_field.custom_field_id] %}{{ address_custom_field[custom_field.custom_field_id] }}{% else %}{{ custom_field.value }}{% endif %}" placeholder="{{ custom_field.name }}" data-date-format="YYYY-MM-DD" id="input-custom-field{{ custom_field.custom_field_id }}" class="{{ input_class }} flex-1 rounded-r-none" />
                  <span class="input-group-btn">
                    <button type="button" class="p-2 rounded-r-sm border border-l-0 border-gray-200 bg-gray-50 text-gray-500 hover:bg-gray-100"><span class="material-symbols-outlined text-[20px]">calendar_today</span></button>
                  </span>
                </div>
                {% if error_custom_field[custom_field.custom_field_id] %}<p class="{{ error_class }}">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
              </div>
              {% endif %}
              {% if custom_field.type == 'time' %}
              <div class="form-group{% if custom_field.required %} required{% endif %} custom-field" data-sort="{{ custom_field.sort_order }}">
                <label class="{{ label_class }}" for="input-custom-field{{ custom_field.custom_field_id }}">{{ custom_field.name }}{% if custom_field.required %} <span class="text-red-500">*</span>{% endif %}</label>
                <div class="input-group time flex">
                  <input type="text" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" value="{% if address_custom_field[custom_field.custom_field_id] %}{{ address_custom_field[custom_field.custom_field_id] }}{% else %}{{ custom_field.value }}{% endif %}" placeholder="{{ custom_field.name }}" data-date-format="HH:mm" id="input-custom-field{{ custom_field.custom_field_id }}" class="{{ input_class }} flex-1 rounded-r-none" />
                  <span class="input-group-btn">
                    <button type="button" class="p-2 rounded-r-sm border border-l-0 border-gray-200 bg-gray-50 text-gray-500 hover:bg-gray-100"><span class="material-symbols-outlined text-[20px]">schedule</span></button>
                  </span>
                </div>
                {% if error_custom_field[custom_field.custom_field_id] %}<p class="{{ error_class }}">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
              </div>
              {% endif %}
              {% if custom_field.type == 'datetime' %}
              <div class="form-group{% if custom_field.required %} required{% endif %} custom-field" data-sort="{{ custom_field.sort_order }}">
                <label class="{{ label_class }}" for="input-custom-field{{ custom_field.custom_field_id }}">{{ custom_field.name }}{% if custom_field.required %} <span class="text-red-500">*</span>{% endif %}</label>
                <div class="input-group datetime flex">
                  <input type="text" name="custom_field[{{ custom_field.location }}][{{ custom_field.custom_field_id }}]" value="{% if address_custom_field[custom_field.custom_field_id] %}{{ address_custom_field[custom_field.custom_field_id] }}{% else %}{{ custom_field.value }}{% endif %}" placeholder="{{ custom_field.name }}" data-date-format="YYYY-MM-DD HH:mm" id="input-custom-field{{ custom_field.custom_field_id }}" class="{{ input_class }} flex-1 rounded-r-none" />
                  <span class="input-group-btn">
                    <button type="button" class="p-2 rounded-r-sm border border-l-0 border-gray-200 bg-gray-50 text-gray-500 hover:bg-gray-100"><span class="material-symbols-outlined text-[20px]">calendar_today</span></button>
                  </span>
                </div>
                {% if error_custom_field[custom_field.custom_field_id] %}<p class="{{ error_class }}">{{ error_custom_field[custom_field.custom_field_id] }}</p>{% endif %}
              </div>
              {% endif %}
              {% endfor %}

              <div class="form-group pt-4 border-t border-gray-100">
                <label class="{{ label_class }}">{{ entry_default }}</label>
                <div class="flex flex-wrap gap-6 pt-2">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="default" value="1" {{ default ? 'checked' : '' }} class="rounded border-gray-300 text-primary focus:ring-luxury-charcoal" />
                    <span class="text-sm text-luxury-charcoal">{{ text_yes }}</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="default" value="0" {{ not default ? 'checked' : '' }} class="rounded border-gray-300 text-primary focus:ring-luxury-charcoal" />
                    <span class="text-sm text-luxury-charcoal">{{ text_no }}</span>
                  </label>
                </div>
              </div>
            </div>

            <div class="flex flex-col-reverse sm:flex-row justify-between items-stretch sm:items-center gap-4 mt-8 pt-6 border-t border-gray-100">
              <a href="{{ back }}" class="inline-flex items-center gap-2 text-primary hover:text-luxury-charcoal transition-colors text-sm font-medium">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                {{ button_back }}
              </a>
              <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-primary-dark transition-colors">
                {{ button_continue }}
              </button>
            </div>
          </form>
        </div>
        {{ content_bottom }}
      </div>
    </div>
  </div>
</main>
<script type="text/javascript"><!--
document.addEventListener('DOMContentLoaded', function() {
	// Sort custom fields
	var form = document.querySelector('main form');
	if (form) {
		var sortFields = Array.from(form.querySelectorAll('.form-group[data-sort]'));
		sortFields.forEach(function(el) {
			var sort = parseInt(el.getAttribute('data-sort'), 10);
			el.remove();
			var formGroups = form.querySelectorAll('.form-group');
			if (sort >= 0 && sort <= formGroups.length - 2) {
				var target = formGroups[sort + 2];
				if (target && target.parentNode) target.parentNode.insertBefore(el, target);
			} else if (sort > formGroups.length - 2 || sort === formGroups.length - 2) {
				var last = formGroups[formGroups.length - 1];
				if (last && last.parentNode) last.parentNode.appendChild(el);
			} else if (sort < -formGroups.length - 2) {
				var first = formGroups[0];
				if (first && first.parentNode) first.parentNode.insertBefore(el, first);
			}
		});
	}

	// Custom field file upload
	document.querySelectorAll('button[id^="button-custom-field"]').forEach(function(btn) {
		btn.addEventListener('click', function() {
			var el = this;
			var oldForm = document.getElementById('form-upload');
			if (oldForm) oldForm.remove();
			var form = document.createElement('form');
			form.id = 'form-upload';
			form.enctype = 'multipart/form-data';
			form.style.display = 'none';
			var input = document.createElement('input');
			input.type = 'file';
			input.name = 'file';
			form.appendChild(input);
			document.body.insertBefore(form, document.body.firstChild);
			input.click();
			var checkInterval = setInterval(function() {
				if (input.value) {
					clearInterval(checkInterval);
					el.disabled = true;
					el.classList.add('opacity-50');
					fetch('index.php?route=tool/upload', {
						method: 'POST',
						body: new FormData(form)
					}).then(function(r) { return r.json(); }).then(function(json) {
						var container = el.closest('.form-group');
						container.querySelectorAll('.text-red-600, .text-danger').forEach(function(e) { e.remove(); });
						if (json.error) {
							var p = document.createElement('p');
							p.className = 'mt-1.5 text-xs text-red-600';
							p.textContent = json.error;
							var hidden = container.querySelector('input[type="hidden"]');
							if (hidden && hidden.parentNode) hidden.parentNode.insertBefore(p, hidden.nextSibling);
						}
						if (json.success) {
							alert(json.success);
							var hidden = container.querySelector('input[type="hidden"]');
							if (hidden) hidden.value = json.code;
						}
					}).catch(function(err) {
						alert(err);
					}).finally(function() {
						el.disabled = false;
						el.classList.remove('opacity-50');
					});
				}
			}, 500);
		});
	});

	// Country / Zone
	var countrySelect = document.querySelector('select[name="country_id"]');
	var zoneSelect = document.querySelector('select[name="zone_id"]');
	var postcodeWrap = document.querySelector('input[name="postcode"]');
	if (postcodeWrap) postcodeWrap = postcodeWrap.closest('.form-group');

	function loadZones(countryId) {
		if (!zoneSelect) return;
		countrySelect.disabled = true;
		fetch('index.php?route=account/account/country&country_id=' + encodeURIComponent(countryId))
			.then(function(r) { return r.json(); })
			.then(function(json) {
				if (postcodeWrap) {
					if (json.postcode_required == '1') postcodeWrap.classList.add('required');
					else postcodeWrap.classList.remove('required');
				}
				var html = '<option value="">{{ text_select|e("js") }}</option>';
				if (json.zone && json.zone.length) {
					for (var i = 0; i < json.zone.length; i++) {
						var sel = json.zone[i].zone_id == '{{ zone_id }}' ? ' selected' : '';
						html += '<option value="' + json.zone[i].zone_id + '"' + sel + '>' + json.zone[i].name + '</option>';
					}
				} else {
					html += '<option value="0" selected>{{ text_none|e("js") }}</option>';
				}
				zoneSelect.innerHTML = html;
			})
			.catch(function(err) { alert(err); })
			.finally(function() { countrySelect.disabled = false; });
	}

	countrySelect.addEventListener('change', function() { loadZones(this.value); });
	loadZones(countrySelect.value);
});
//--></script>
{{ footer }}
