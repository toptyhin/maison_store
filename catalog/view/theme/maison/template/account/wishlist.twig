{{ header }}
<main class="flex-1 bg-background-dark">
{{ include('maison/template/account/account_header.twig') }}
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
    {% if success %}
    <div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800 flex items-center gap-2">
      <span class="material-symbols-outlined text-[20px]">check_circle</span>
      {{ success }}
    </div>
    {% endif %}
    <div class="flex flex-col lg:flex-row gap-8">
      {{ menu }}
      <div class="flex-1 min-w-0">
        {{ content_top }}
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
          <div>
            <h1 class="text-3xl font-serif text-luxury-charcoal font-medium">{{ heading_title }}</h1>
          </div>
        </div>
        {% if products %}
        <div class="bg-white rounded-lg shadow-soft border border-gray-100 overflow-hidden">
          <div class="overflow-x-auto">
            <div class="min-w-[640px]">
              {% for product in products %}
              {% if not loop.first %}
              <div class="border-t border-gray-100"></div>
              {% endif %}
              <div class="flex flex-col sm:flex-row gap-6 p-6 items-start">
                <div class="w-full sm:w-32 aspect-square rounded-sm overflow-hidden bg-gray-100 shrink-0 border border-gray-200">
                  {% if product.thumb %}
                  <a href="{{ product.href }}">
                    <img src="{{ product.thumb }}" alt="{{ product.name }}" class="w-full h-full object-cover" />
                  </a>
                  {% endif %}
                </div>
                <div class="flex-1 w-full min-w-0">
                  <a href="{{ product.href }}" class="block text-lg font-serif font-medium text-luxury-charcoal mb-1 hover:text-primary transition-colors">
                    {{ product.name }}
                  </a>
                  {% if product.model %}
                  <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">{{ product.model }}</p>
                  {% endif %}
                  <p class="text-sm text-gray-500">{{ product.stock }}</p>
                  <div class="flex flex-wrap items-center justify-between gap-4 mt-4">
                    <div class="flex items-center gap-2">
                      {% if product.price %}
                      <div class="price">
                        {% if not product.special %}
                        <span class="text-xl font-bold text-luxury-charcoal">{{ product.price }}</span>
                        {% else %}
                        <span class="text-xl font-bold text-luxury-charcoal">{{ product.special }}</span>
                        <s class="text-sm text-gray-400 ml-1">{{ product.price }}</s>
                        {% endif %}
                      </div>
                      {% endif %}
                    </div>
                    <div class="flex items-center gap-2">
                      <button type="button" onclick="cart.add('{{ product.product_id }}');" data-toggle="tooltip" title="{{ button_cart }}" class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-white text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-primary-dark transition-colors">
                        <span class="material-symbols-outlined text-[18px]">shopping_cart</span>
                        {{ button_cart }}
                      </button>
                      <a href="{{ product.remove }}" data-toggle="tooltip" title="{{ button_remove }}" class="inline-flex items-center gap-2 px-4 py-2 text-red-500 hover:bg-red-50 rounded-sm transition-colors">
                        <span class="material-symbols-outlined text-[18px]">delete</span>
                        {{ button_remove }}
                      </a>
                    </div>
                  </div>
                </div>
              </div>
              {% endfor %}
            </div>
          </div>
        </div>
        {% else %}
        <div class="bg-white rounded-lg shadow-soft border border-gray-100 p-12 text-center">
          <span class="material-symbols-outlined text-6xl text-gray-300 mb-4 block">favorite</span>
          <p class="text-gray-500 mb-6">{{ text_empty }}</p>
          <a href="{{ continue }}" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-primary-dark transition-colors">
            {{ button_continue }}
          </a>
        </div>
        {% endif %}
        {% if products %}
        <div class="mt-6">
          <a href="{{ continue }}" class="inline-flex items-center gap-2 text-primary hover:text-luxury-charcoal transition-colors text-sm font-medium">
            <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            {{ button_continue }}
          </a>
        </div>
        {% endif %}
        {{ content_bottom }}
      </div>
    </div>
  </div>
</main>
{{ footer }}
