              <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 p-6 items-start sm:items-center">
                <div class="flex-1 w-full min-w-0 grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
                  <div>
                    <span class="text-gray-500 block text-xs uppercase tracking-widest mb-0.5">{{ column_document_type }}</span>
                    <span class="text-luxury-charcoal">{{ document.document_type }}</span>
                  </div>
                  <div>
                    <span class="text-gray-500 block text-xs uppercase tracking-widest mb-0.5">{{ column_filename }}</span>
                    <span class="text-luxury-charcoal">{{ document.filename }}</span>
                  </div>
                  <div>
