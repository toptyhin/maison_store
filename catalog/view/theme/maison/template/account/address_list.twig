{{ header }}
<main class="flex-1 bg-background-dark">
	{{ include('maison/template/account/account_header.twig') }}
	<div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
		{% if success %}
			<div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800 flex items-center gap-2">
				<span class="material-symbols-outlined text-[20px]">check_circle</span>
				{{ success }}
			</div>
		{% endif %}
		{% if error_warning %}
			<div class="mb-6 rounded-lg bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800 flex items-center gap-2">
				<span class="material-symbols-outlined text-[20px]">warning</span>
				{{ error_warning }}
			</div>
		{% endif %}
		<div class="flex flex-col lg:flex-row gap-8">
			{{ menu }}
			<div class="flex-1 min-w-0">
				{{ content_top }}
				<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
					<div>
						<h1 class="text-3xl font-serif text-luxury-charcoal font-medium">{{ heading_title }}</h1>
						<p class="text-gray-500 mt-1 text-sm">{{ text_address_book }}</p>
					</div>
					<div class="flex gap-3">
						<a href="{{ add }}" class="flex items-center gap-2 bg-[#263238] text-white px-6 py-3 rounded-md hover:bg-primary transition-colors text-xs font-bold uppercase tracking-widest shadow-md">
							<span class="material-symbols-outlined text-[18px]">add</span>
							{{ button_new_address }}
						</a>
					</div>
				</div>
				{% if addresses %}
					<div class="bg-white rounded-lg shadow-soft border border-gray-100 overflow-hidden">
						{# <div class="divide-y divide-gray-100"> #}
            <div class="grid grid-cols-1 gap-6">
							{% for result in addresses %}
								<div class="flex flex-col sm:flex-row gap-4 sm:gap-6 p-6 items-start sm:items-center">
									<div class="flex-1 min-w-0">
										<div class="text-luxury-charcoal text-sm leading-relaxed">{{ result.address|raw }}</div>
									</div>
									<div class="flex items-center gap-2 shrink-0">
										<a href="{{ result.update }}" class="inline-flex items-center gap-2 px-4 py-2 bg-[#263238] text-white text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-primary-dark transition-colors">
											<span class="material-symbols-outlined text-[18px]">edit</span>
											{{ button_edit }}
										</a>
										<a href="{{ result.delete }}" class="inline-flex items-center gap-2 px-4 py-2 text-red-500 hover:bg-red-50 rounded-sm transition-colors" onclick="return confirm('{{ text_confirm }}')" title="{{ button_delete }}">
											<span class="material-symbols-outlined text-[18px]">delete</span>
											{{ button_delete }}
										</a>
									</div>
								</div>
                
							{% endfor %}
						</div>
					</div>
				{% else %}
					<div class="bg-white rounded-lg shadow-soft border border-gray-100 p-12 text-center">
						<span class="material-symbols-outlined text-6xl text-gray-300 mb-4 block">location_off</span>
						<p class="text-gray-500 mb-6">{{ text_empty }}</p>
						<a href="{{ add }}" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-primary-dark transition-colors">
							<span class="material-symbols-outlined text-[18px]">add</span>
							{{ button_new_address }}
						</a>
					</div>
				{% endif %}
				<div class="mt-6">
					<a href="{{ back }}" class="inline-flex items-center gap-2 text-primary hover:text-luxury-charcoal transition-colors text-sm font-medium">
						<span class="material-symbols-outlined text-[20px]">arrow_back</span>
						{{ button_back }}
					</a>
				</div>
				{{ content_bottom }}
			</div>
		</div>
	</div>
</main>
{{ footer }}
