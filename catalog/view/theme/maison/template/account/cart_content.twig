{{ content_top }}
{% if success %}
<div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800 flex items-center gap-2">
  <span class="material-symbols-outlined text-[20px]">check_circle</span>
  {{ success }}
</div>
{% endif %}
{% if error_warning %}
<div class="mb-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800 flex items-center gap-2">
  <span class="material-symbols-outlined text-[20px]">warning</span>
  {{ error_warning }}
</div>
{% endif %}
<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
  <div>
    <h1 class="text-3xl font-serif text-luxury-charcoal font-medium">{{ heading_title }}</h1>
    <p class="text-gray-500 mt-1 text-sm">{{ products_count }} {{ text_items_count }}</p>
  </div>
  {% if products %}
  <div class="flex gap-3">
    <a href="{{ action_clear }}" class="cart-clear-btn flex items-center gap-2 bg-white border border-gray-200 px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-luxury-charcoal hover:border-primary hover:text-primary transition-all duration-300 rounded-sm shadow-sm">
      <span class="material-symbols-outlined text-[18px]">delete_sweep</span>
      {{ button_clear }}
    </a>
  </div>
  {% endif %}
</div>

{% if show_discount_block %}
{# Блок скидки #}
<div class="bg-white rounded-lg shadow-soft border border-gray-100 p-6 mb-8 relative overflow-hidden">
  <div class="absolute right-0 top-0 h-full w-1/3 bg-gradient-to-l from-primary/5 to-transparent pointer-events-none"></div>
  <div class="flex flex-col md:flex-row justify-between items-start mb-4 relative z-10">
    <div>
      <h2 class="text-lg font-serif font-bold text-luxury-charcoal">{{ text_discount }}</h2>
    </div>
    {% if text_discount_progress %}
    <p class="text-sm font-medium text-luxury-charcoal bg-gray-50 px-3 py-1.5 rounded-md border border-gray-100 mt-2 md:mt-0">
      {{ text_discount_progress }}
    </p>
    {% endif %}
  </div>
  {# p = доля суммы до max-порога; колонки следующего уровня — равная ширина; жёлтый — заливка внутри колонки следующего уровня, порог ещё не достигнут #}
  {% set p = discount_progress_percent %}
  {% set n_tiers = discount_tiers|length %}
  {% set tier_width_pct = n_tiers > 0 ? (100 / n_tiers) : 100 %}
  {% set next_tier_idx = -1 %}
  {% for tier in discount_tiers %}
    {% if next_tier_idx < 0 and sub_total_value < tier.threshold %}
      {% set next_tier_idx = loop.index0 %}
    {% endif %}
  {% endfor %}
  {% set seg_left = (next_tier_idx >= 0 and n_tiers > 0) ? (100 * next_tier_idx / n_tiers) : 0 %}
  {% set green1_w = next_tier_idx < 0 ? p : min(p, seg_left) %}
  {# Жёлтый: от левого края колонки следующего (ещё не достигнутого) уровня до конца заливки — без «ложного» зелёного хвоста до порога #}
  {% set yellow_w = (next_tier_idx >= 0 and p > seg_left) ? (p - seg_left) : 0 %}
  <div class="relative w-full h-8 bg-gray-100 rounded-full mt-2 mb-2 overflow-hidden">
    {% if green1_w > 0 %}
    <div class="absolute top-0 left-0 z-10 h-full bg-positive-green bg-green-500 transition-all duration-500 ease-out" style="width: {{ green1_w }}%;">
      <div class="absolute inset-0 bg-white/20 animate-pulse pointer-events-none"></div>
    </div>
    {% endif %}
    {% if yellow_w > 0 %}
    {# Цвет и z-index inline: в tailwind.bundle нет bg-amber-400 и z-[11], иначе полоса без фона / под зелёным #}
    <div class="absolute top-0 left-0 z-10 h-full transition-all duration-500 ease-out" style="left: {{ seg_left }}%; width: {{ yellow_w }}%; background-color: #EAB308; box-shadow: inset 0 0 0 1px rgba(0,0,0,.06);">
      <div class="absolute inset-0 bg-white/10 pointer-events-none"></div>
    </div>
    {% endif %}
    <div class="absolute top-0 left-0 z-20 w-full h-full flex justify-between items-center px-2 text-xs font-bold text-gray-500 pointer-events-none">
      {% for tier in discount_tiers %}
      <div class="relative h-full flex items-center justify-center transition-colors duration-500 {{ not loop.last ? 'border-r border-white/50' : '' }}" style="width: {{ tier_width_pct }}%;">
        <span class="relative z-10 transition-colors duration-500 {{ sub_total_value >= tier.threshold ? 'mix-blend-screen text-white' : 'mix-blend-multiply text-gray-400' }}">{{ tier.percent }}%</span>
        <span class="absolute bottom-full mb-2 text-[10px] {{ sub_total_value >= tier.threshold ? 'text-luxury-charcoal font-bold' : 'text-gray-400 font-normal' }} whitespace-nowrap">{{ tier.threshold_text }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
  <p class="text-sm text-gray-500 mt-1 relative z-10">Текущая скидка: <span class="font-bold text-primary text-lg">{{ current_discount }}%</span></p>
</div>
{% endif %}

{# Быстрое добавление #}
<div class="bg-white rounded-lg shadow-soft border border-gray-100 p-6 mb-8">
  <h2 class="text-sm font-bold uppercase tracking-widest text-luxury-charcoal mb-4">Быстрое добавление</h2>
  <form method="post" action="{{ action_add_sku }}" id="form-add-sku" class="flex flex-col md:flex-row gap-4 items-center">
    <input type="hidden" name="product_id" id="add-product-id" value=""/>
    <input type="hidden" name="product_option_id" id="add-product-option-id" value=""/>
    <input type="hidden" name="product_option_value_id" id="add-product-option-value-id" value=""/>
    <div class="relative flex-1 w-full" id="cart-sku-wrapper">
      <span class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400 material-symbols-outlined z-10">search</span>
      <input name="sku" id="cart-sku-input" class="w-full pl-12 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-md focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-sm placeholder-gray-400 text-luxury-charcoal" placeholder="{{ placeholder_sku }}" type="text" autocomplete="off"/>
      <div id="cart-sku-dropdown" class="absolute left-0 right-0 top-full mt-1 bg-white border border-gray-200 rounded-md shadow-lg z-50 max-h-72 overflow-y-auto hidden"></div>
    </div>
    <button type="submit" class="w-full md:w-auto flex items-center justify-center gap-2 bg-luxury-charcoal text-white px-6 py-3 rounded-md hover:bg-primary transition-colors text-xs font-bold uppercase tracking-widest whitespace-nowrap">
      <span class="material-symbols-outlined text-[18px]">add</span>
      {{ button_add }}
    </button>
    <div class="h-8 w-px bg-gray-200 hidden md:block mx-2"></div>
    <a href="{{ action_export_excel }}" class="w-full md:w-auto flex items-center justify-center gap-2 bg-white border border-gray-200 text-luxury-charcoal px-6 py-3 rounded-md hover:border-primary hover:text-primary transition-colors text-xs font-bold uppercase tracking-widest whitespace-nowrap">
      <span class="material-symbols-outlined text-[18px]">download_for_offline</span>
      {{ button_export_excel }}
    </a>
  </form>
</div>

{% if products %}
{# Таблица товаров #}
<div class="w-full bg-white rounded-lg shadow-soft border border-gray-100 overflow-hidden mb-8">
  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm text-gray-500">
      <thead class="bg-gray-50 text-xs uppercase text-gray-400 font-bold tracking-wider">
        <tr>
          <th class="px-6 py-4 font-semibold w-24">{{ column_image }}</th>
          <th class="px-6 py-4 font-semibold">{{ column_product }}</th>
          <th class="px-6 py-4 font-semibold text-right">{{ column_price }}</th>
          <th class="px-6 py-4 font-semibold text-right text-primary">{{ column_your_price }}</th>
          <th class="px-6 py-4 font-semibold text-center w-32">{{ column_quantity }}</th>
          <th class="px-6 py-4 font-semibold text-right">{{ column_total }}</th>
          <th class="px-6 py-4 font-semibold w-10"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% for product in products %}
        <tr class="hover:bg-gray-50/50 transition-colors group">
          <td class="px-6 py-4">
            <div class="size-16 bg-gray-100 rounded-md overflow-hidden border border-gray-200">
              <a href="{{ product.href }}"><img alt="{{ product.name }}" class="w-full h-full object-cover" src="{{ product.thumb }}"/></a>
            </div>
          </td>
          <td class="px-6 py-4">
            <p class="text-xs font-bold text-gray-400 mb-1">{{ product.model }}</p>
            <a href="{{ product.href }}" class="text-sm font-bold text-luxury-charcoal line-clamp-2 hover:text-primary">{{ product.name }}</a>
            {% if product.option_text %}<p class="text-xs text-gray-500 mt-1">{{ product.option_text }}</p>{% endif %}
          </td>
          <td class="px-6 py-4 text-right">
            {% if product.old_price %}<p class="font-medium text-discount-red line-through whitespace-nowrap">{{ product.old_price }}</p>{% endif %}
          </td>
          <td class="px-6 py-4 text-right">
            <p class="font-bold text-luxury-charcoal text-base whitespace-nowrap">{{ product.price }}</p>
          </td>
          <td class="px-6 py-4">
            <div class="flex items-center justify-center">
              <div class="flex items-center border border-gray-200 rounded-md bg-white">
                <button type="button" class="cart-qty-minus px-2 py-1 hover:bg-gray-100 text-gray-500 transition-colors" data-cart-id="{{ product.cart_id }}">-</button>
                <input class="cart-qty-input w-12 text-center border-none p-1 text-sm text-luxury-charcoal focus:ring-0" type="number" value="{{ product.quantity }}" min="1" data-cart-id="{{ product.cart_id }}"/>
                <button type="button" class="cart-qty-plus px-2 py-1 hover:bg-gray-100 text-gray-500 transition-colors" data-cart-id="{{ product.cart_id }}">+</button>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 text-right">
            <p class="cart-product-total font-bold text-luxury-charcoal whitespace-nowrap" data-cart-id="{{ product.cart_id }}">{{ product.total }}</p>
          </td>
          <td class="px-6 py-4 text-center">
            <a href="#" class="cart-remove-btn inline-block text-gray-300 hover:text-red-500 transition-colors" data-cart-id="{{ product.cart_id }}" data-remove-url="{{ product.remove|e('html_attr') }}" title="Удалить">
              <span class="material-symbols-outlined text-[20px]">delete</span>
            </a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{# Итого и оформление #}
<div class="w-full bg-white rounded-lg shadow-card-depth border border-gray-100 p-8">
  <div class="flex flex-col lg:flex-row justify-between items-center gap-8">
    <div class="flex flex-wrap gap-8 lg:gap-12 flex-1 justify-start w-full lg:w-auto items-center">
      {% if weight %}
      <div class="flex flex-col gap-1">
        <span class="text-xs text-gray-400 uppercase tracking-widest font-bold">{{ text_weight }}</span>
        <span class="text-xl font-medium text-luxury-charcoal">{{ weight }}</span>
      </div>
      {% endif %}
      {% if volume %}
      <div class="flex flex-col gap-1">
        <span class="text-xs text-gray-400 uppercase tracking-widest font-bold">{{ text_volume }}</span>
        <span class="text-xl font-medium text-luxury-charcoal">{{ volume }}</span>
      </div>
      {% endif %}
    </div>
    <div class="flex flex-col sm:flex-row gap-8 w-full lg:w-auto mt-4 lg:mt-0 items-center">
      <div class="flex flex-col gap-1 text-right">
        <span class="text-xs text-gray-400 uppercase tracking-widest font-bold">{{ text_total }}</span>
        <span class="text-3xl font-serif font-bold text-luxury-charcoal whitespace-nowrap" id="cart-order-total">{{ order_total_text }}</span>
      </div>
      <a href="{{ checkout }}" class="flex-1 sm:flex-none whitespace-nowrap bg-[#263238] text-white px-8 py-4 rounded-sm text-xs font-bold uppercase tracking-widest hover:bg-primary transition-colors shadow-lg flex items-center justify-center gap-2">
        {{ button_checkout }}
        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
      </a>
    </div>
  </div>
</div>
{% else %}
{# Пустая корзина #}
<div class="bg-white rounded-lg shadow-soft border border-gray-100 p-12 text-center">
  <span class="material-symbols-outlined text-6xl text-gray-300 mb-4 block">shopping_cart</span>
  <p class="text-gray-500 mb-6">{{ text_empty }}</p>
  <a href="{{ continue }}" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-primary-dark transition-colors">
    {{ button_continue }}
  </a>
</div>
{% endif %}
{{ content_bottom }}
