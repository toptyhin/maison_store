              {{ text_wishlist }}
            </a>
            {% if reward %}
            <a class="flex items-center gap-3 px-4 py-3 {{ menu_active is defined and menu_active == 'reward' ? 'bg-[#263238] text-white' : 'text-luxury-charcoal hover:bg-gray-50 hover:text-primary' }} rounded-md transition-colors font-medium text-sm {{ menu_active is defined and menu_active == 'reward' ? 'shadow-md' : '' }}" href="{{ reward }}">
              <span class="material-symbols-outlined text-[20px]">loyalty</span>
              {{ text_reward }}
            </a>
            {% endif %}
            <a class="flex items-center gap-3 px-4 py-3 {{ (menu_active is not defined or menu_active == 'account') ? 'bg-[#263238] text-white' : 'text-luxury-charcoal hover:bg-gray-50 hover:text-primary' }} rounded-md transition-colors font-medium text-sm {{ (menu_active is not defined or menu_active == 'account') ? 'shadow-md' : '' }}" href="{{ account }}">
              <span class="material-symbols-outlined text-[20px]">person</span>
              {{ text_edit }}
            </a>
            <a class="flex items-center gap-3 px-4 py-3 {{ menu_active is defined and menu_active == 'address' ? 'bg-[#263238] text-white' : 'text-luxury-charcoal hover:bg-gray-50 hover:text-primary' }} rounded-md transition-colors font-medium text-sm {{ menu_active is defined and menu_active == 'address' ? 'shadow-md' : '' }}" href="{{ address }}">
