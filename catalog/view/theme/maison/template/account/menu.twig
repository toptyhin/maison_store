              {{ text_order }}
            </a>
            <a class="flex items-center gap-3 px-4 py-3 {{ menu_active is defined and menu_active == 'wishlist' ? 'bg-[#263238] text-white' : 'text-luxury-charcoal hover:bg-gray-50 hover:text-primary' }} rounded-md transition-colors font-medium text-sm {{ menu_active is defined and menu_active == 'wishlist' ? 'shadow-md' : '' }}" href="{{ wishlist }}">
