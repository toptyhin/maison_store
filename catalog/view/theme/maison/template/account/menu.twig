            </a>
            {% endfor %}
            <div class="h-px bg-gray-100 my-2"></div>
            <a class="flex items-center gap-3 px-4 py-3 text-red-500 hover:bg-red-50 rounded-md transition-colors font-medium text-sm" href="{{ logout }}">
              <span class="material-symbols-outlined text-[20px]">logout</span>
              {{ text_logout }}
            </a>
          </div>
        </nav>
      </aside>