{{ header }}
<main class="flex-1 bg-background-dark mt-24">
	{{ include('maison/template/account/account_header.twig') }}
	<div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
		<div class="flex flex-col lg:flex-row gap-8">
			{{ menu }}
			<div class="flex-1 min-w-0">
				{{ content_top }}
				<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
					<div>
						<h1 class="text-3xl font-serif text-luxury-charcoal font-medium">{{ heading_title }}</h1>
						<p class="text-gray-500 mt-1 text-sm">{{ text_company_book }}</p>
					</div>
					<a href="{{ back }}" class="inline-flex items-center gap-2 text-primary hover:text-luxury-charcoal transition-colors text-sm font-medium">
						<span class="material-symbols-outlined text-[20px]">arrow_back</span>
						{{ button_back }}
					</a>
				</div>

				{% set input_class = 'w-full rounded-sm border border-gray-200 bg-gray-50 py-3 px-4 text-sm text-luxury-charcoal focus:border-luxury-charcoal focus:ring-0 focus:bg-white placeholder:text-gray-400 transition-colors' %}
				{% set label_class = 'block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2' %}
				{% set error_class = 'mt-1.5 text-xs text-red-600' %}

				<div class="bg-white rounded-lg shadow-soft border border-gray-100 overflow-hidden mb-6">
					<div class="p-6 border-b border-gray-100">
						<h2 class="text-lg font-serif text-luxury-charcoal font-bold">{{ text_company }}</h2>
					</div>
					<form action="{{ action }}" method="post" enctype="multipart/form-data" class="p-6">
						<div class="space-y-6">
							<div class="form-group">
								<label class="{{ label_class }}" for="input-company">{{ entry_company }} <span class="text-red-500">*</span></label>
								<input type="text" name="company" value="{{ company }}" placeholder="{{ entry_company }}" id="input-company" class="{{ input_class }}{% if error_company %} border-red-300{% endif %}" />
								{% if error_company %}<p class="{{ error_class }}">{{ error_company }}</p>{% endif %}
							</div>

							<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
								<div class="form-group">
									<label class="{{ label_class }}" for="input-inn">{{ entry_inn }} <span class="text-red-500">*</span></label>
									<input type="text" name="inn" value="{{ inn }}" placeholder="{{ entry_inn }}" id="input-inn" class="{{ input_class }}{% if error_inn %} border-red-300{% endif %}" />
									{% if error_inn %}<p class="{{ error_class }}">{{ error_inn }}</p>{% endif %}
								</div>
								<div class="form-group">
									<label class="{{ label_class }}" for="input-kpp">{{ entry_kpp }}</label>
									<input type="text" name="kpp" value="{{ kpp }}" placeholder="{{ entry_kpp }}" id="input-kpp" class="{{ input_class }}{% if error_kpp %} border-red-300{% endif %}" />
									{% if error_kpp %}<p class="{{ error_class }}">{{ error_kpp }}</p>{% endif %}
								</div>
							</div>

							<div class="form-group">
								<label class="{{ label_class }}" for="input-address">{{ entry_address }} <span class="text-red-500">*</span></label>
								<input type="text" name="address" value="{{ address }}" placeholder="{{ entry_address }}" id="input-address" class="{{ input_class }}{% if error_address %} border-red-300{% endif %}" />
								{% if error_address %}<p class="{{ error_class }}">{{ error_address }}</p>{% endif %}
							</div>

							<div class="form-group">
								<label class="{{ label_class }}" for="input-bik">{{ entry_bik }} <span class="text-red-500">*</span></label>
								<input type="text" name="bik" value="{{ bik }}" placeholder="{{ entry_bik }}" id="input-bik" class="{{ input_class }}{% if error_bik %} border-red-300{% endif %}" />
								{% if error_bik %}<p class="{{ error_class }}">{{ error_bik }}</p>{% endif %}
							</div>

							<div class="form-group">
								<label class="{{ label_class }}" for="input-bank">{{ entry_bank }} <span class="text-red-500">*</span></label>
								<input type="text" name="bank" value="{{ bank }}" placeholder="{{ entry_bank }}" id="input-bank" class="{{ input_class }}{% if error_bank %} border-red-300{% endif %}" />
								{% if error_bank %}<p class="{{ error_class }}">{{ error_bank }}</p>{% endif %}
							</div>

							<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
								<div class="form-group">
									<label class="{{ label_class }}" for="input-rs">{{ entry_rs }} <span class="text-red-500">*</span></label>
									<input type="text" name="rs" value="{{ rs }}" placeholder="{{ entry_rs }}" id="input-rs" class="{{ input_class }}{% if error_rs %} border-red-300{% endif %}" />
									{% if error_rs %}<p class="{{ error_class }}">{{ error_rs }}</p>{% endif %}
								</div>
								<div class="form-group">
									<label class="{{ label_class }}" for="input-ks">{{ entry_ks }}</label>
									<input type="text" name="ks" value="{{ ks }}" placeholder="{{ entry_ks }}" id="input-ks" class="{{ input_class }}{% if error_ks %} border-red-300{% endif %}" />
									{% if error_ks %}<p class="{{ error_class }}">{{ error_ks }}</p>{% endif %}
								</div>
							</div>
						</div>

						<div class="flex flex-col-reverse sm:flex-row justify-between items-stretch sm:items-center gap-4 mt-8 pt-6 border-t border-gray-100">
							<a href="{{ back }}" class="inline-flex items-center gap-2 text-primary hover:text-luxury-charcoal transition-colors text-sm font-medium">
								<span class="material-symbols-outlined text-[20px]">arrow_back</span>
								{{ button_back }}
							</a>
							<button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white text-sm font-bold uppercase tracking-widest rounded-sm hover:bg-primary-dark transition-colors">
								{{ button_continue }}
							</button>
						</div>
					</form>
				</div>
				{{ content_bottom }}
			</div>
		</div>
	</div>
</main>
{{ footer }}
