{{ header }}
<div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden bg-background-dark font-display text-luxury-charcoal antialiased">
  <main class="flex-1 w-full max-w-7xl mx-auto px-6 lg:px-12 py-12 mt-24">
    {# Breadcrumbs #}
    <nav class="mb-8">
      <ol class="flex flex-wrap items-center gap-2 text-sm">
        {% for breadcrumb in breadcrumbs %}
          <li class="flex items-center gap-2">
            {% if not loop.first %}
              <span class="text-gray-300">/</span>
            {% endif %}
            {% if loop.last %}
              <span class="text-gray-500 font-medium">{{ breadcrumb.text }}</span>
            {% else %}
              <a href="{{ breadcrumb.href }}" class="text-gray-500 hover:text-luxury-charcoal transition-colors">{{ breadcrumb.text }}</a>
            {% endif %}
          </li>
        {% endfor %}
      </ol>
    </nav>

    {% if success %}
      <div class="mb-6 rounded-md border border-emerald-100 bg-emerald-50 px-4 py-3 text-sm text-emerald-900 flex items-start gap-2">
        <span class="material-symbols-outlined text-[18px] mt-0.5 shrink-0">check_circle</span>
        <div class="flex-1">{{ success }}</div>
      </div>
    {% endif %}

    {% if error_warning %}
      <div class="mb-6 rounded-md border border-red-100 bg-red-50 px-4 py-3 text-sm text-red-900 flex items-start gap-2">
        <span class="material-symbols-outlined text-[18px] mt-0.5 shrink-0">error</span>
        <div class="flex-1">{{ error_warning }}</div>
      </div>
    {% endif %}

    <h1 class="text-3xl md:text-4xl font-serif font-bold text-luxury-charcoal mb-10">{{ heading_title }}</h1>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      {# Новый покупатель #}
      <section class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-full pointer-events-none"></div>
        <div class="relative z-10">
          <div class="size-14 bg-gray-50 rounded-full flex items-center justify-center text-primary mb-6 border border-gray-100">
            <span class="material-symbols-outlined text-[28px]">person_add</span>
          </div>
          <h2 class="text-xl font-serif font-medium text-luxury-charcoal mb-3">{{ text_new_customer }}</h2>
          <p class="text-sm text-gray-600 leading-relaxed mb-6">{{ text_register_account }}</p>
          <p class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-3">{{ text_customer_type }}</p>
          <div class="flex flex-wrap gap-6 mb-6">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="login_customer_type" value="retail" checked="checked"
                class="rounded border-gray-300 text-primary focus:ring-luxury-charcoal" />
              <span class="text-sm text-luxury-charcoal">{{ text_customer_type_retail }}</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="login_customer_type" value="wholesale"
                class="rounded border-gray-300 text-primary focus:ring-luxury-charcoal" />
              <span class="text-sm text-luxury-charcoal">{{ text_customer_type_wholesale }}</span>
            </label>
          </div>
          <a id="link-register" href="{{ register }}" data-href-retail="{{ register }}" data-href-wholesale="{{ register_wholesale }}"
            class="inline-flex items-center justify-center gap-2 w-full sm:w-auto bg-luxury-charcoal text-white border border-transparent px-8 py-4 rounded-sm text-xs font-bold uppercase tracking-[0.15em] hover:bg-primary-dark transition-colors shadow-sm group">
            {{ text_register }}
            <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
          </a>
        </div>
      </section>

      {# Постоянный покупатель #}
      <section class="bg-white rounded-lg p-6 md:p-8 shadow-soft border border-gray-100 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-full pointer-events-none"></div>
        <div class="relative z-10">
          <div class="size-14 bg-gray-50 rounded-full flex items-center justify-center text-primary mb-6 border border-gray-100">
            <span class="material-symbols-outlined text-[28px]">login</span>
          </div>
          <h2 class="text-xl font-serif font-medium text-luxury-charcoal mb-3">{{ text_returning_customer }}</h2>
          <p class="text-sm text-gray-600 mb-6">{{ text_i_am_returning_customer }}</p>

          <form action="{{ action }}" method="post" enctype="multipart/form-data" class="flex flex-col gap-5">
            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2" for="input-email">{{ entry_email }}</label>
              <input type="email" name="email" value="{{ email }}" placeholder="{{ entry_email }}" id="input-email"
                class="w-full rounded-sm border border-gray-200 bg-gray-50 py-3 px-4 text-sm text-luxury-charcoal focus:border-luxury-charcoal focus:ring-0 focus:bg-white placeholder:text-gray-400 transition-colors" />
            </div>
            <div>
              <div class="flex items-center justify-between mb-2">
                <label class="block text-xs font-bold uppercase tracking-widest text-gray-500" for="input-password">{{ entry_password }}</label>
                <a href="{{ forgotten }}" class="text-xs text-gray-500 hover:text-primary transition-colors">{{ text_forgotten }}</a>
              </div>
              <input type="password" name="password" value="{{ password }}" placeholder="{{ entry_password }}" id="input-password"
                class="w-full rounded-sm border border-gray-200 bg-gray-50 py-3 px-4 text-sm text-luxury-charcoal focus:border-luxury-charcoal focus:ring-0 focus:bg-white placeholder:text-gray-400 transition-colors" />
            </div>
            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 bg-luxury-charcoal text-white border border-transparent py-4 rounded-sm text-xs font-bold uppercase tracking-[0.15em] hover:bg-primary-dark transition-colors shadow-sm">
              {{ button_login }}
              <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </button>
            {% if redirect %}
              <input type="hidden" name="redirect" value="{{ redirect }}" />
            {% endif %}
          </form>
        </div>
      </section>
    </div>

    {{ content_top }}
    {{ content_bottom }}
  </main>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var link = document.getElementById('link-register');
  if (!link || !link.dataset.hrefRetail) return;
  function syncRegisterHref() {
    var wholesale = document.querySelector('input[name="login_customer_type"]:checked');
    link.href = (wholesale && wholesale.value === 'wholesale') ? link.dataset.hrefWholesale : link.dataset.hrefRetail;
  }
  document.querySelectorAll('input[name="login_customer_type"]').forEach(function(r) {
    r.addEventListener('change', syncRegisterHref);
  });
  syncRegisterHref();
});
</script>
{{ footer }}
